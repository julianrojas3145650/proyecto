<Window x:Class="Proyecto_senavicola.view.dialogs.Cerrar_sesion"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        Background="Transparent"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Title="Cerrar sesión"
        Height="200"
        Width="300"
        WindowStartupLocation="CenterScreen">
    
    <Border CornerRadius="15" Background="White" BorderBrush="#179002" BorderThickness="2">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#179002" CornerRadius="15,15,0,0">
                <Grid>
                    <TextBlock Text="Cerrar sesión" 
                               FontSize="20" 
                               FontWeight="Bold" 
                               Foreground="White" 
                               VerticalAlignment="Center" 
                               Margin="20,0"/>
                    <Button Content="✕" 
                            HorizontalAlignment="Right" 
                            VerticalAlignment="Center" 
                            Width="40" 
                            Height="40" 
                            Background="Transparent" 
                            Foreground="White" 
                            BorderThickness="0" 
                            FontSize="20" 
                            Cursor="Hand" 
                            Click="BtnCancelar_Click" 
                            Margin="0,0,10,0"/>
                </Grid>
            </Border>
            <StackPanel Grid.Row="1" 
                        Margin="20" 
                        HorizontalAlignment="Center">
                <TextBlock Text="¿Seguro que quieres cerrar sesión?" 
                           FontSize="14" 
                           Margin="0 0 0 15"
                           TextAlignment="Center"/> 

                <UniformGrid Rows="1" 
                             Columns="2" 
                             HorizontalAlignment="Center" 
                             Margin="0,10,0,0">
                    <Button Content="Sí" 
                            Width="70" 
                            Margin="5" 
                            Click="BtnYes_Click"/>
                    <Button Content="No" 
                            Width="70" 
                            Margin="5" 
                            Click="BtnNo_Click"/>
                </UniformGrid>
            </StackPanel>
        </Grid>
    </Border>
</Window>
