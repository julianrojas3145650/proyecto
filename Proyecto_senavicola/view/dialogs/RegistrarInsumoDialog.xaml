<Window x:Class="Proyecto_senavicola.view.dialogs.RegistrarInsumoDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Registrar Insumo" 
        Height="650" 
        Width="500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        Background="Transparent"
        AllowsTransparency="True"
        ResizeMode="NoResize">

    <Border CornerRadius="15" 
            Background="White" 
            BorderBrush="#179002" 
            BorderThickness="2">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#179002" CornerRadius="15,15,0,0">
                <Grid>
                    <TextBlock x:Name="txtTitulo" 
                               Text="📦 Registrar Insumo" 
                               FontSize="20" 
                               FontWeight="Bold" 
                               Foreground="White" 
                               VerticalAlignment="Center" 
                               Margin="20,0"/>
                    <Button Content="✕" 
                            HorizontalAlignment="Right" 
                            VerticalAlignment="Center" 
                            Width="40" 
                            Height="40" 
                            Background="Transparent" 
                            Foreground="White" 
                            BorderThickness="0" 
                            FontSize="20" 
                            Cursor="Hand" 
                            Click="BtnCancelar_Click" 
                            Margin="0,0,10,0"/>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" Margin="30,20">
                <StackPanel>
                    <TextBlock Text="Nombre del Insumo *" FontSize="12" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtNombre" Height="35" Padding="10" Margin="0,0,0,15"/>

                    <TextBlock Text="Tipo *" FontSize="12" Margin="0,0,0,5"/>
                    <ComboBox x:Name="CmbTipo" Height="35" Margin="0,0,0,15">
                        <ComboBoxItem Content="Alimento" IsSelected="True"/>
                        <ComboBoxItem Content="Herramienta"/>
                        <ComboBoxItem Content="Medicamento"/>
                        <ComboBoxItem Content="Utensilio"/>
                        <ComboBoxItem Content="Otro"/>
                    </ComboBox>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,5,0">
                            <TextBlock Text="Cantidad *" FontSize="12" Margin="0,0,0,5"/>
                            <TextBox x:Name="TxtCantidad" Height="35" Padding="10"
                                     PreviewTextInput="NumericTextBox_PreviewTextInput"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="5,0,0,0">
                            <TextBlock Text="Unidad *" FontSize="12" Margin="0,0,0,5"/>
                            <ComboBox x:Name="CmbUnidad" Height="35">
                                <ComboBoxItem Content="kg" IsSelected="True"/>
                                <ComboBoxItem Content="g"/>
                                <ComboBoxItem Content="L"/>
                                <ComboBoxItem Content="ml"/>
                                <ComboBoxItem Content="unidad"/>
                                <ComboBoxItem Content="paquete"/>
                                <ComboBoxItem Content="bulto"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Stock Mínimo" FontSize="12" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtStockMinimo" Height="35" Padding="10" Margin="0,0,0,15"
                             Text="0" PreviewTextInput="NumericTextBox_PreviewTextInput"/>

                    <TextBlock Text="Fecha de Vencimiento (Opcional)" FontSize="12" Margin="0,0,0,5"/>
                    <DatePicker x:Name="DpVencimiento" Height="35" Margin="0,0,0,15"/>

                    <TextBlock Text="Proveedor" FontSize="12" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtProveedor" Height="35" Padding="10" Margin="0,0,0,15"/>

                    <TextBlock Text="Precio Unitario" FontSize="12" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtPrecio" Height="35" Padding="10" Margin="0,0,0,15"
                             Text="0" PreviewTextInput="NumericTextBox_PreviewTextInput"/>

                    <TextBlock Text="Observaciones" FontSize="12" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtObservaciones" 
                             Height="80" 
                             Padding="10" 
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"/>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Background="#F5F5F5" Padding="20" CornerRadius="0,0,15,15">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancelar" 
                            Width="100" 
                            Height="35" 
                            Background="#666666" 
                            Foreground="White" 
                            BorderThickness="0" 
                            Cursor="Hand" 
                            Margin="0,0,10,0"
                            Click="BtnCancelar_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="8" 
                                        Padding="15,8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="btnRegistrar" 
                            Content="Registrar" 
                            Width="100" 
                            Height="35" 
                            Background="#179002" 
                            Foreground="White" 
                            BorderThickness="0" 
                            Cursor="Hand"
                            Click="BtnRegistrar_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="8" 
                                        Padding="15,8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>