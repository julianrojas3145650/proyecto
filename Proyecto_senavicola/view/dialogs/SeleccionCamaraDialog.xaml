<Window x:Class="Proyecto_senavicola.view.dialogs.SeleccionCamaraDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Seleccionar Cámara" 
        WindowStyle="None"
        Height="500" 
        Width="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Window.Resources>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#179002"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1FA303"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F0F0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="White" 
            CornerRadius="10" 
            Margin="10" 
            BorderBrush="#E0E0E0" 
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" 
                              Opacity="0.1" 
                              BlurRadius="10" ShadowDepth="2"/>
        </Border.Effect>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="📷 Seleccionar Cámara" 
                         FontSize="20" FontWeight="Bold" Foreground="#179002"/>
                <TextBlock Text="Se detectaron múltiples cámaras, selecciona la que deseas usar" 
                         FontSize="12" Foreground="#666666" Margin="0,5,0,0" TextWrapping="Wrap"/>
            </StackPanel>

            <Border Grid.Row="1" Background="#F9F9F9" CornerRadius="8" Padding="10">
                <ListBox x:Name="lstCamaras" Background="Transparent" BorderThickness="0"
             SelectionMode="Single" SelectionChanged="LstCamaras_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="ItemBorder" Background="White" CornerRadius="6" Padding="15" Margin="0,5"
                        BorderThickness="2" BorderBrush="Transparent">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="5" ShadowDepth="1"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Icono de cámara -->
                                    <TextBlock Grid.Column="0" Text="📹" FontSize="24" 
                                 VerticalAlignment="Center" Margin="0,0,15,0"/>

                                    <!-- Información de la cámara -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14"/>
                                        <TextBlock Text="{Binding MonikerString}" FontSize="10" 
                                     Foreground="#999999" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>

                                    <!-- ✅ CHULITO cuando está seleccionado -->
                                    <Border x:Name="CheckMark" Grid.Column="3" 
                                Background="#179002" 
                                CornerRadius="12" 
                                Width="24" Height="24"
                                VerticalAlignment="Center"
                                Visibility="Collapsed">
                                        <TextBlock Text="✓" FontSize="16" FontWeight="Bold" 
                                     Foreground="White" 
                                     HorizontalAlignment="Center" 
                                     VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- ✅ Trigger para cambiar apariencia cuando está seleccionado -->
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#179002"/>
                                    <Setter TargetName="ItemBorder" Property="Background" Value="#F0F9EE"/>
                                    <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>

                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Border>

            <Grid Grid.Row="2" Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="Cancelar" 
                      Style="{StaticResource SecondaryButtonStyle}" 
                      Margin="0,0,5,0" Click="Cancelar_Click"/>

                <Button x:Name="btnSeleccionar" Grid.Column="1" Content="Seleccionar" 
                      Style="{StaticResource PrimaryButtonStyle}" 
                      Margin="5,0,0,0" Click="Seleccionar_Click" IsEnabled="False"/>
            </Grid>
        </Grid>
    </Border>
</Window>