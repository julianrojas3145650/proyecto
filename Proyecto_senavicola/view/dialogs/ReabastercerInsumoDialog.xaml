<Window x:Class="Proyecto_senavicola.view.dialogs.ReabastecerInsumoDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reabastecer Insumo" 
        Height="350" 
        Width="450"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        Background="Transparent"
        AllowsTransparency="True"
        ResizeMode="NoResize">

    <Border CornerRadius="15" Background="White" BorderBrush="#4CAF50" BorderThickness="2">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#4CAF50" CornerRadius="15,15,0,0">
                <Grid>
                    <TextBlock Text="➕ Reabastecer Insumo" 
                               FontSize="20" 
                               FontWeight="Bold" 
                               Foreground="White" 
                               VerticalAlignment="Center" 
                               Margin="20,0"/>
                    <Button Content="✕" 
                            HorizontalAlignment="Right" 
                            VerticalAlignment="Center" 
                            Width="40" 
                            Height="40" 
                            Background="Transparent" 
                            Foreground="White" 
                            BorderThickness="0" 
                            FontSize="20" 
                            Cursor="Hand" 
                            Click="BtnCancelar_Click" 
                            Margin="0,0,10,0">
                    </Button>
                </Grid>
            </Border>
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                <StackPanel Margin="30,20">
                    <Border Background="#E8F5E9" CornerRadius="8" Padding="15" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock x:Name="txtNombreInsumo" 
                                       Text="Insumo" 
                                       FontWeight="SemiBold" 
                                       FontSize="14" 
                                       Margin="0,0,0,5"/>
                            <TextBlock x:Name="txtCantidadActual" 
                                       Text="Cantidad actual: 0" 
                                       FontSize="12" 
                                       Foreground="#666"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Cantidad a Agregar *" FontSize="12" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtCantidad" 
                             Height="35" 
                             Padding="10" 
                             Margin="0,0,0,15"
                             PreviewTextInput="NumericTextBox_PreviewTextInput"/>

                    <TextBlock Text="Observaciones" FontSize="12" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtObservaciones" 
                             Height="60" 
                             Padding="10" 
                             TextWrapping="Wrap" 
                             AcceptsReturn="True"/>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Background="#F5F5F5" Padding="20" CornerRadius="0,0,15,15">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancelar" 
                            Width="100" 
                            Height="35" 
                            Background="#666666" 
                            Foreground="White" 
                            BorderThickness="0" 
                            Cursor="Hand" 
                            Margin="0,0,10,0"
                            Click="BtnCancelar_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="8" 
                                        Padding="15,8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="Reabastecer" 
                            Width="120" 
                            Height="35" 
                            Background="#4CAF50" 
                            Foreground="White" 
                            BorderThickness="0" 
                            Cursor="Hand"
                            Click="BtnReabastecer_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="8" 
                                        Padding="15,8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>