<Window x:Class="Proyecto_senavicola.view.dialogs.RegistrarLoteDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Registrar Lote de Gallinas" 
        Height="550" 
        Width="500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        Background="Transparent"
        AllowsTransparency="True"
        ResizeMode="NoResize">

    <Border CornerRadius="15" Background="White" BorderBrush="#179002" BorderThickness="2">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Cabecera -->
            <Border Grid.Row="0" Background="#179002" CornerRadius="15,15,0,0">
                <Grid>
                    <TextBlock Text="📦 Registrar Lote de Gallinas" 
                               FontSize="20" 
                               FontWeight="Bold" 
                               Foreground="White" 
                               VerticalAlignment="Center" 
                               Margin="20,0"/>
                    <Button Content="✕" 
                            HorizontalAlignment="Right" 
                            VerticalAlignment="Center" 
                            Width="40" 
                            Height="40" 
                            Background="Transparent" 
                            Foreground="White" 
                            BorderThickness="0" 
                            FontSize="20" 
                            Cursor="Hand" 
                            Click="BtnCancelar_Click" 
                            Margin="0,0,10,0"/>
                </Grid>
            </Border>

            <!-- Contenido -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="30,20">
                <StackPanel>
                    <TextBlock Text="Código del Lote *" FontSize="12" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtCodigo" Height="35" Padding="10" Margin="0,0,0,15"/>

                    <TextBlock Text="Cantidad de Gallinas *" FontSize="12" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtCantidad" Height="35" Padding="10" Margin="0,0,0,15"
                             PreviewTextInput="NumericTextBox_PreviewTextInput"/>

                    <TextBlock Text="Raza *" FontSize="12" Margin="0,0,0,5"/>
                    <ComboBox x:Name="cmbRaza" Height="35" Margin="0,0,0,15">
                        <ComboBoxItem Content="Rhode Island Red"/>
                        <ComboBoxItem Content="Leghorn Blanca"/>
                        <ComboBoxItem Content="Plymouth Rock"/>
                        <ComboBoxItem Content="Sussex"/>
                        <ComboBoxItem Content="Australorp"/>
                        <ComboBoxItem Content="Otra" IsSelected="True"/>
                    </ComboBox>

                    <TextBlock Text="Edad en Semanas" FontSize="12" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtEdad" Height="35" Padding="10" Margin="0,0,0,15"
                             PreviewTextInput="NumericTextBox_PreviewTextInput"/>

                    <TextBlock Text="Fecha de Llegada *" FontSize="12" Margin="0,0,0,5"/>
                    <DatePicker x:Name="dpFecha" Height="35" Margin="0,0,0,15" 
                                SelectedDate="{Binding Path=Today, Mode=OneTime}"/>

                    <TextBlock Text="Proveedor" FontSize="12" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtProveedor" Height="35" Padding="10" Margin="0,0,0,15"/>

                    <TextBlock Text="Observaciones" FontSize="12" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtObservaciones" 
                             Height="80" 
                             Padding="10" 
                             TextWrapping="Wrap" 
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Pie -->
            <Border Grid.Row="2" Background="#F5F5F5" Padding="20" CornerRadius="0,0,15,15">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancelar" 
                            Width="100" 
                            Height="35" 
                            Background="#666666" 
                            Foreground="White" 
                            BorderThickness="0" 
                            Cursor="Hand" 
                            Margin="0,0,10,0"
                            Click="BtnCancelar_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="8" 
                                        Padding="15,8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="Registrar" 
                            Width="100" 
                            Height="35" 
                            Background="#179002" 
                            Foreground="White" 
                            BorderThickness="0" 
                            Cursor="Hand"
                            Click="BtnRegistrar_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="8" 
                                        Padding="15,8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>