<Window x:Class="Proyecto_senavicola.view.dialogs.EditarHuevoDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Editar Huevo" 
        Height="500" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Window.Resources>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#179002"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1FA303"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F0F0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                        Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#179002"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="10" Margin="10" 
            BorderBrush="#E0E0E0" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.1" BlurRadius="10" ShadowDepth="2"/>
        </Border.Effect>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="✏️ Editar Registro de Huevo" 
                         FontSize="20" FontWeight="Bold" Foreground="#179002"/>
                <TextBlock x:Name="txtInfoHuevo" Text="" 
                         FontSize="12" Foreground="#666666" Margin="0,5,0,0"/>
            </StackPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Grid.Row="1"
                            Margin="0,70,0,0">
                    <TextBlock Text="Tipo de Huevo:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <Border Background="#F9F9F9" CornerRadius="6" Padding="10" Margin="0,0,0,15">
                        <TextBlock x:Name="txtTipo" Text="" FontSize="14" Foreground="#666666"/>
                    </Border>

                    <TextBlock Text="Cantidad:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtCantidad" Style="{StaticResource ModernTextBox}" 
                       Margin="0,0,0,15" PreviewTextInput="NumericTextBox_PreviewTextInput"/>

                    <TextBlock Text="Peso Promedio (gramos):" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <Grid Margin="0,0,0,15">
                        <TextBox x:Name="txtPeso" Style="{StaticResource ModernTextBox}"
                           Padding="10,10,40,10" PreviewTextInput="NumericTextBox_PreviewTextInput"
                           TextChanged="TxtPeso_TextChanged"/>
                        <TextBlock Text="g" VerticalAlignment="Center" HorizontalAlignment="Right"
                             Margin="0,0,15,0" Foreground="#666666" IsHitTestVisible="False"/>
                    </Grid>

                    <Border x:Name="borderNuevoTipo" Background="#FFF3E0" CornerRadius="8" 
                      Padding="15" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="⚠️ Cambio de Clasificación" FontWeight="SemiBold" 
                                 Foreground="#FF9800" Margin="0,0,0,5"/>
                            <TextBlock x:Name="txtNuevoTipo" Text="" 
                                 TextWrapping="Wrap" FontSize="12" Foreground="#666666"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Row="2" Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="Cancelar" 
                      Style="{StaticResource SecondaryButtonStyle}" 
                      Margin="0,0,5,0" Click="Cancelar_Click"/>

                <Button Grid.Column="1" Content="Guardar Cambios" 
                      Style="{StaticResource PrimaryButtonStyle}" 
                      Margin="5,0,0,0" Click="Guardar_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>