<Window x:Class="Proyecto_senavicola.view.dialogs.SeleccionarAlimentoDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Seleccionar Alimento"
        Height="350" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="🥣 Seleccionar Alimento" 
                   FontSize="20" FontWeight="Bold" 
                   Foreground="#179002" Margin="0,0,0,15"/>

        <Border Grid.Row="1" Background="White" 
                CornerRadius="8" Padding="20">
            <StackPanel>
                <TextBlock x:Name="TxtCantidadNecesaria" 
                           Text="Cantidad necesaria: 0 kg" 
                           FontSize="14" Foreground="#666" 
                           Margin="0,0,0,15"/>

                <TextBlock Text="Alimento a usar:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <ComboBox x:Name="CmbAlimentos" Height="35" FontSize="14"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Cancelar" Width="100" Height="35"
                    Background="#9E9E9E" Foreground="White"
                    BorderThickness="0" Margin="0,0,10,0"
                    Click="BtnCancelar_Click"
                    Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="5" Padding="12,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="Confirmar" Width="100" Height="35"
                    Background="#4CAF50" Foreground="White"
                    BorderThickness="0"
                    Click="BtnConfirmar_Click"
                    Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="5" Padding="12,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>