<Window x:Class="Proyecto_senavicola.view.dialogs.DetalleLoteDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detalle del Lote" 
        Height="600" 
        Width="700"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        Background="Transparent"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Loaded="Window_Loaded">

    <Border CornerRadius="15" Background="White" BorderBrush="#179002" BorderThickness="2">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Cabecera -->
            <Border Grid.Row="0" Background="#179002" CornerRadius="15,15,0,0">
                <Grid>
                    <TextBlock x:Name="txtTitulo" 
                               Text="📦 Detalle del Lote" 
                               FontSize="20" 
                               FontWeight="Bold" 
                               Foreground="White" 
                               VerticalAlignment="Center" 
                               Margin="20,0"/>
                    <Button Content="✕" 
                            HorizontalAlignment="Right" 
                            VerticalAlignment="Center" 
                            Width="40" 
                            Height="40" 
                            Background="Transparent" 
                            Foreground="White" 
                            BorderThickness="0" 
                            FontSize="20" 
                            Cursor="Hand" 
                            Click="BtnCerrar_Click" 
                            Margin="0,0,10,0"/>
                </Grid>
            </Border>

            <!-- Contenido -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" Margin="30,20">
                <StackPanel>
                    <!-- Información General -->
                    <TextBlock Text="Información General" 
                               FontSize="16" 
                               FontWeight="SemiBold" 
                               Margin="0,0,0,15"/>

                    <Border Background="#F5F5F5" CornerRadius="8" Padding="15" Margin="0,0,0,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Código Lote:" FontWeight="SemiBold"/>
                            <TextBlock x:Name="txtCodigoLote" Grid.Row="0" Grid.Column="1" Text=""/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Raza:" FontWeight="SemiBold"/>
                            <TextBlock x:Name="txtRaza" Grid.Row="2" Grid.Column="1" Text=""/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Edad:" FontWeight="SemiBold"/>
                            <TextBlock x:Name="txtEdad" Grid.Row="4" Grid.Column="1" Text=""/>

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Fecha Llegada:" FontWeight="SemiBold"/>
                            <TextBlock x:Name="txtFechaLlegada" Grid.Row="6" Grid.Column="1" Text=""/>

                            <TextBlock Grid.Row="8" Grid.Column="0" Text="Proveedor:" FontWeight="SemiBold"/>
                            <TextBlock x:Name="txtProveedor" Grid.Row="8" Grid.Column="1" Text=""/>

                            <TextBlock Grid.Row="10" Grid.Column="0" Text="Observaciones:" FontWeight="SemiBold"/>
                            <TextBlock x:Name="txtObservaciones" Grid.Row="10" Grid.Column="1" Text="" TextWrapping="Wrap"/>
                        </Grid>
                    </Border>

                    <!-- Estadísticas -->
                    <TextBlock Text="Estadísticas" 
                               FontSize="16" 
                               FontWeight="SemiBold" 
                               Margin="0,0,0,15"/>

                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#E8F5E9" CornerRadius="8" Padding="15" Margin="0,0,5,0">
                            <StackPanel>
                                <TextBlock Text="Total" FontSize="12" Foreground="#666" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="txtTotal" 
                                           Text="0" 
                                           FontSize="28" 
                                           FontWeight="Bold" 
                                           Foreground="#4CAF50" 
                                           HorizontalAlignment="Center" 
                                           Margin="0,5,0,0"/>
                                <TextBlock Text="gallinas" FontSize="10" Foreground="#666" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="#E3F2FD" CornerRadius="8" Padding="15" Margin="5,0">
                            <StackPanel>
                                <TextBlock Text="Asignadas" FontSize="12" Foreground="#666" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="txtAsignadas" 
                                           Text="0" 
                                           FontSize="28" 
                                           FontWeight="Bold" 
                                           Foreground="#2196F3" 
                                           HorizontalAlignment="Center" 
                                           Margin="0,5,0,0"/>
                                <TextBlock Text="gallinas" FontSize="10" Foreground="#666" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="#FFF3E0" CornerRadius="8" Padding="15" Margin="5,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Pendientes" FontSize="12" Foreground="#666" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="txtPendientes" 
                                           Text="0" 
                                           FontSize="28" 
                                           FontWeight="Bold" 
                                           Foreground="#FF9800" 
                                           HorizontalAlignment="Center" 
                                           Margin="0,5,0,0"/>
                                <TextBlock Text="gallinas" FontSize="10" Foreground="#666" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Historial de Asignaciones -->
                    <TextBlock Text="Historial de Asignaciones" 
                               FontSize="16" 
                               FontWeight="SemiBold" 
                               Margin="0,0,0,15"/>

                    <DataGrid x:Name="dgAsignaciones" 
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              BorderThickness="1"
                              BorderBrush="#E0E0E0"
                              AlternatingRowBackground="#F9F9F9"
                              RowHeight="40"
                              MaxHeight="200">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Fecha" Binding="{Binding FechaAsignacion, StringFormat=dd/MM/yyyy HH:mm}" Width="150"/>
                            <DataGridTextColumn Header="Galpón" Binding="{Binding CodigoGalpon}" Width="120"/>
                            <DataGridTextColumn Header="Cantidad" Binding="{Binding Cantidad}" Width="100"/>
                            <DataGridTextColumn Header="Usuario" Binding="{Binding UsuarioNombre}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </ScrollViewer>

            <!-- Pie -->
            <Border Grid.Row="2" Background="#F5F5F5" Padding="20" CornerRadius="0,0,15,15">
                <Button Content="Cerrar" 
                        Width="100" 
                        Height="35" 
                        Background="#666666" 
                        Foreground="White" 
                        BorderThickness="0" 
                        Cursor="Hand"
                        Click="BtnCerrar_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                    CornerRadius="8" 
                                    Padding="15,8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Border>
        </Grid>
    </Border>
</Window>