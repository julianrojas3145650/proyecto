<Window x:Class="Proyecto_senavicola.view.dialogs.GalponDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestión de Galpón"
        Height="450" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
            <Setter Property="Foreground" Value="#333"/>
        </Style>

        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Encabezado -->
        <Border Grid.Row="0" Background="White" Padding="20" 
                BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock x:Name="TxtTitulo" Text="Nuevo Galpón" 
                           FontSize="20" FontWeight="Bold" Foreground="#333"/>
                <TextBlock Text="Completa la información del galpón" 
                           FontSize="13" Foreground="#666" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Formulario -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
            <Border Background="White" Margin="20" Padding="20" CornerRadius="8">
                <StackPanel>
                    <!-- Nombre del galpón -->
                    <TextBlock Text="Nombre del Galpón *" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="TxtNombre" 
                             Style="{StaticResource TextBoxStyle}"
                             Margin="0,0,0,15"/>

                    <!-- Raza -->
                    <TextBlock Text="Raza de las Gallinas *" Style="{StaticResource LabelStyle}"/>
                    <ComboBox x:Name="CmbRaza" 
                              Style="{StaticResource ComboBoxStyle}"
                              Margin="0,0,0,15"
                              IsEditable="True">
                        <ComboBoxItem Content="Rhode Island Red"/>
                        <ComboBoxItem Content="Leghorn"/>
                        <ComboBoxItem Content="Plymouth Rock"/>
                        <ComboBoxItem Content="Sussex"/>
                        <ComboBoxItem Content="Brahma"/>
                        <ComboBoxItem Content="Orpington"/>
                        <ComboBoxItem Content="Wyandotte"/>
                        <ComboBoxItem Content="Australorp"/>
                        <ComboBoxItem Content="Otra"/>
                    </ComboBox>

                    <!-- Longitud -->
                    <TextBlock Text="Longitud del Galpón (metros) *" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="TxtLongitud" 
                             Style="{StaticResource TextBoxStyle}"
                             Margin="0,0,0,15"
                             PreviewTextInput="NumeroDecimal_PreviewTextInput"/>

                    <!-- Ración por ave -->
                    <TextBlock Text="Ración de Comida por Ave (gramos) *" Style="{StaticResource LabelStyle}"/>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="TxtRacion" 
                                 Grid.Column="0"
                                 Style="{StaticResource TextBoxStyle}"
                                 Text="120"
                                 PreviewTextInput="NumeroDecimal_PreviewTextInput"/>

                        <TextBlock Grid.Column="1" Text="g" 
                                   FontSize="13" Foreground="#666"
                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </Grid>

                    <!-- Información adicional -->
                    <Border Background="#E8F5E9" Padding="12" CornerRadius="5" Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="ℹ️ Información" 
                                       FontWeight="SemiBold" FontSize="12" 
                                       Foreground="#2E7D32" Margin="0,0,0,5"/>
                            <TextBlock Text="• La ración por defecto es 120g por ave" 
                                       FontSize="11" Foreground="#4CAF50" Margin="0,2"/>
                            <TextBlock Text="• Puedes modificar este valor según tus necesidades" 
                                       FontSize="11" Foreground="#4CAF50" Margin="0,2"/>
                            <TextBlock Text="• Las gallinas se pueden agregar después" 
                                       FontSize="11" Foreground="#4CAF50" Margin="0,2"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Botones de acción -->
        <Border Grid.Row="2" Background="White" Padding="20" 
                BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1" Content="Cancelar" 
                        Width="100" Height="35"
                        Background="#9E9E9E" Foreground="White"
                        BorderThickness="0" FontWeight="SemiBold"
                        Margin="0,0,10,0"
                        Click="BtnCancelar_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                    CornerRadius="5" 
                                    Padding="15,8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Grid.Column="2" Content="Guardar" 
                        Width="100" Height="35"
                        Background="#4CAF50" Foreground="White"
                        BorderThickness="0" FontWeight="SemiBold"
                        Click="BtnGuardar_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                    CornerRadius="5" 
                                    Padding="15,8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>