<Window x:Class="Proyecto_senavicola.view.dialogs.AgregarGallinasDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Agregar Gallinas"
        Height="600" Width="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
            <Setter Property="Foreground" Value="#333"/>
        </Style>

        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Padding="20" 
                BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="Agregar Gallinas al Galpón" 
                           FontSize="20" FontWeight="Bold" Foreground="#333"/>
                <TextBlock x:Name="TxtGalponInfo" Text="Galpón: -" 
                           FontSize="13" Foreground="#666" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
            <Border Background="White" Margin="20" Padding="20" CornerRadius="8">
                <StackPanel>

                    <TextBlock Text="Cantidad de Gallinas a Registrar *" Style="{StaticResource LabelStyle}"/>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="TxtCantidad" 
                                 Grid.Column="0"
                                 Style="{StaticResource TextBoxStyle}"
                                 Text="1"
                                 PreviewTextInput="NumeroEntero_PreviewTextInput"
                                 TextChanged="TxtCantidad_TextChanged"/>

                        <Button Grid.Column="1" Content="Generar Nombres"
                                Width="140" Height="35"
                                Background="#2196F3" Foreground="White"
                                BorderThickness="0" FontWeight="SemiBold"
                                Margin="10,0,0,0"
                                Click="BtnGenerarNombres_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            CornerRadius="5" 
                                            Padding="15,8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <Border Background="#E3F2FD" Padding="12" CornerRadius="5" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="ℹ️ Instrucciones" 
                                       FontWeight="SemiBold" FontSize="12" 
                                       Foreground="#1976D2" Margin="0,0,0,5"/>
                            <TextBlock Text="• Ingresa la cantidad de gallinas que deseas agregar" 
                                       FontSize="11" Foreground="#2196F3" Margin="0,2"/>
                            <TextBlock Text="• Presiona 'Generar Nombres' para crear los campos automáticamente" 
                                       FontSize="11" Foreground="#2196F3" Margin="0,2"/>
                            <TextBlock Text="• Puedes editar los nombres generados antes de guardar" 
                                       FontSize="11" Foreground="#2196F3" Margin="0,2"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Nombres de las Gallinas" Style="{StaticResource LabelStyle}" Margin="0,10,0,10"/>

                    <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5" 
                            MaxHeight="300">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="ListaGallinas" Padding="10">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="120"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" 
                                                       Text="{Binding Numero, StringFormat={}#{0}}" 
                                                       FontWeight="SemiBold" FontSize="12"
                                                       VerticalAlignment="Center" Foreground="#666"/>

                                            <TextBox Grid.Column="1" 
                                                     Text="{Binding Nombre, UpdateSourceTrigger=PropertyChanged}" 
                                                     Height="32" Padding="8,5" FontSize="12"
                                                     BorderBrush="#CCCCCC" BorderThickness="1"
                                                     VerticalContentAlignment="Center"
                                                     Margin="0,0,10,0"/>

                                            <ComboBox Grid.Column="2" 
                                                      SelectedItem="{Binding Estado}" 
                                                      Height="32" FontSize="12"
                                                      BorderBrush="#CCCCCC" BorderThickness="1"
                                                      Margin="0,0,10,0">
                                                <ComboBoxItem Content="Activa" IsSelected="True"/>
                                                <ComboBoxItem Content="En observación"/>
                                                <ComboBoxItem Content="Enferma"/>
                                            </ComboBox>

                                            <TextBox Grid.Column="3" 
                                                     Text="{Binding Peso, UpdateSourceTrigger=PropertyChanged}" 
                                                     Height="32" Padding="8,5" FontSize="12"
                                                     BorderBrush="#CCCCCC" BorderThickness="1"
                                                     VerticalContentAlignment="Center">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox">
                                                        <Style.Triggers>
                                                            <Trigger Property="Text" Value="">
                                                                <Setter Property="Background" Value="White"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <Grid Margin="0,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="#" FontSize="10" Foreground="#999"/>
                        <TextBlock Grid.Column="1" Text="Nombre" FontSize="10" Foreground="#999" Margin="0,0,10,0"/>
                        <TextBlock Grid.Column="2" Text="Estado" FontSize="10" Foreground="#999" Margin="0,0,10,0"/>
                        <TextBlock Grid.Column="3" Text="Peso (g) opcional" FontSize="10" Foreground="#999"/>
                    </Grid>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <Border Grid.Row="2" Background="White" Padding="20" 
                BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Total a agregar: " FontSize="13" Foreground="#666"/>
                    <TextBlock x:Name="TxtTotalGallinas" Text="0" 
                               FontSize="13" FontWeight="Bold" Foreground="#4CAF50"/>
                    <TextBlock Text=" gallinas" FontSize="13" Foreground="#666"/>
                </StackPanel>

                <Button Grid.Column="1" Content="Cancelar" 
                        Width="100" Height="35"
                        Background="#9E9E9E" Foreground="White"
                        BorderThickness="0" FontWeight="SemiBold"
                        Margin="0,0,10,0"
                        Click="BtnCancelar_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                    CornerRadius="5" 
                                    Padding="15,8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Grid.Column="2" Content="Guardar Todo" 
                        Width="120" Height="35"
                        Background="#4CAF50" Foreground="White"
                        BorderThickness="0" FontWeight="SemiBold"
                        Click="BtnGuardar_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                    CornerRadius="5" 
                                    Padding="15,8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>