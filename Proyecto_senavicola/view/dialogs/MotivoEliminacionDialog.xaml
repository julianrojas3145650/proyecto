<Window x:Class="Proyecto_senavicola.view.dialogs.MotivoEliminacionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Motivo de Eliminación" 
        Height="500" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Window.Resources>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#179002"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1FA303"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F0F0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                        Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#179002"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernRadioButton" TargetType="RadioButton">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="10" Margin="10" 
            BorderBrush="#E0E0E0" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.1" BlurRadius="10" ShadowDepth="2"/>
        </Border.Effect>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="🗑️ Eliminar Registro de Inventario" 
                         FontSize="20" FontWeight="Bold" Foreground="#179002"/>
                <TextBlock x:Name="txtInfoHuevo" Text="" 
                         FontSize="12" Foreground="#666666" Margin="0,5,0,0"/>
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                <StackPanel>
                    <TextBlock Text="Selecciona el motivo:" FontWeight="SemiBold" Margin="0,0,0,10"/>

                    <Border Background="#F9F9F9" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                        <StackPanel>
                            <RadioButton x:Name="rbVendido" Content="💰 Vendido" 
                                       Style="{StaticResource ModernRadioButton}"
                                       IsChecked="True"
                                       Checked="RbVendido_Checked"/>
                            <RadioButton x:Name="rbDanado" Content="❌ Dañado" 
                                       Style="{StaticResource ModernRadioButton}"
                                       Checked="RbDanado_Checked"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Cantidad:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtCantidad" Style="{StaticResource ModernTextBox}" 
                           Margin="0,0,0,15" PreviewTextInput="NumericTextBox_PreviewTextInput"/>

                    <StackPanel x:Name="panelVendido" Visibility="Visible">
                        <TextBlock Text="Precio Unitario:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <Grid Margin="0,0,0,15">
                            <TextBox x:Name="txtPrecioUnitario" Style="{StaticResource ModernTextBox}"
                                   Padding="25,10,10,10" PreviewTextInput="NumericTextBox_PreviewTextInput"/>
                            <TextBlock Text="$" VerticalAlignment="Center" Margin="10,0,0,0" 
                                     Foreground="#666666" IsHitTestVisible="False"/>
                        </Grid>

                        <TextBlock Text="Cliente:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtCliente" Style="{StaticResource ModernTextBox}" 
                               Margin="0,0,0,15"/>

                        <Border Background="#E8F5E9" CornerRadius="8" Padding="15">
                            <Grid>
                                <TextBlock Text="Total:" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <TextBlock x:Name="txtTotal" Text="$0.00" 
                                         FontSize="18" FontWeight="Bold" Foreground="#179002"
                                         HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <StackPanel x:Name="panelDanado" Visibility="Collapsed">
                        <TextBlock Text="Motivo del daño:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cmbMotivoDano" FontSize="14" Padding="10" 
                                Margin="0,0,0,15" Background="White">
                            <ComboBoxItem Content="Huevo roto/quebrado"/>
                            <ComboBoxItem Content="Huevo sucio"/>
                            <ComboBoxItem Content="Huevo con sangre"/>
                            <ComboBoxItem Content="Huevo deformado"/>
                            <ComboBoxItem Content="Huevo con olor extraño"/>
                            <ComboBoxItem Content="Vencido"/>
                            <ComboBoxItem Content="Otro" IsSelected="True"/>
                        </ComboBox>

                        <TextBlock Text="Observaciones:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtObservaciones" Style="{StaticResource ModernTextBox}"
                               Height="80" TextWrapping="Wrap" 
                               AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Row="2" Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="Cancelar" 
                      Style="{StaticResource SecondaryButtonStyle}" 
                      Margin="0,0,5,0" Click="Cancelar_Click"/>

                <Button Grid.Column="1" Content="Confirmar" 
                      Style="{StaticResource PrimaryButtonStyle}" 
                      Margin="5,0,0,0" Click="Confirmar_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>