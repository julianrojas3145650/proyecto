<Window x:Class="Proyecto_senavicola.view.dialogs.EditarGallinaDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Editar Gallina"
        Height="400" Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
            <Setter Property="Foreground" Value="#333"/>
        </Style>

        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Padding="20" 
                BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="Editar Información de Gallina" 
                           FontSize="20" FontWeight="Bold" Foreground="#333"/>
                <TextBlock Text="Modifica los datos de la gallina seleccionada" 
                           FontSize="13" Foreground="#666" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" Margin="20" Padding="20" CornerRadius="8">
            <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Hidden">
            <StackPanel>
                <TextBlock Text="ID de la Gallina" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="TxtId" 
                         Style="{StaticResource TextBoxStyle}"
                         IsReadOnly="True"
                         Background="#F0F0F0"
                         Margin="0,0,0,15"/>

                <TextBlock Text="Nombre de la Gallina" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="TxtNombre" 
                         Style="{StaticResource TextBoxStyle}"
                         Margin="0,0,0,15"/>

                <TextBlock Text="Estado *" Style="{StaticResource LabelStyle}"/>
                <ComboBox x:Name="CmbEstado" 
                          Style="{StaticResource ComboBoxStyle}"
                          Margin="0,0,0,15">
                    <ComboBoxItem Content="Activa"/>
                    <ComboBoxItem Content="En observación"/>
                    <ComboBoxItem Content="Enferma"/>
                    <ComboBoxItem Content="Vendida"/>
                    <ComboBoxItem Content="Fallecida"/>
                </ComboBox>

                <TextBlock Text="Peso (gramos) - Opcional" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="TxtPeso" 
                         Style="{StaticResource TextBoxStyle}"
                         PreviewTextInput="NumeroDecimal_PreviewTextInput"
                         Margin="0,0,0,15"/>

                <TextBlock Text="Fecha de Ingreso" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="TxtFechaIngreso" 
                         Style="{StaticResource TextBoxStyle}"
                         IsReadOnly="True"
                         Background="#F0F0F0"/>
            </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2" Background="White" Padding="20" 
                BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1" Content="Cancelar" 
                        Width="100" Height="35"
                        Background="#9E9E9E" Foreground="White"
                        BorderThickness="0" FontWeight="SemiBold"
                        Margin="0,0,10,0"
                        Click="BtnCancelar_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                    CornerRadius="5" 
                                    Padding="15,8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Grid.Column="2" Content="Guardar" 
                        Width="100" Height="35"
                        Background="#4CAF50" Foreground="White"
                        BorderThickness="0" FontWeight="SemiBold"
                        Click="BtnGuardar_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                    CornerRadius="5" 
                                    Padding="15,8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>