<Window x:Class="Proyecto_senavicola.view.dialogs.CambiarContraseñaDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cambiar Contraseña"
        Height="450"
        Width="500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        Background="Transparent"
        AllowsTransparency="True"
        ResizeMode="NoResize">

    <Border Background="White" CornerRadius="15" Padding="30">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.3"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Encabezado -->
            <StackPanel Grid.Row="0" Margin="0,0,0,25">
                <TextBlock Text="🔐" FontSize="40" HorizontalAlignment="Center"/>
                <TextBlock Text="Cambiar Contraseña" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="#179002"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,5"/>
                <TextBlock Text="Actualiza la contraseña de cualquier rol" 
                           FontSize="12" 
                           Foreground="#666666"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Formulario -->
            <StackPanel Grid.Row="1">

                <!-- Seleccionar Rol -->
                <TextBlock Text="Selecciona el rol" 
                           FontSize="12" 
                           FontWeight="SemiBold"
                           Foreground="#333333"
                           Margin="0,0,0,8"/>

                <Border BorderThickness="2"
                        BorderBrush="#E0E0E0"
                        CornerRadius="10"
                        Background="White"
                        Margin="0,0,0,20">
                    <ComboBox x:Name="cmbRol"
                              FontSize="14"
                              Padding="12,10"
                              BorderThickness="0"
                              Background="Transparent">
                        <ComboBoxItem Content="👔 Administrador" Tag="Administrador"/>
                        <ComboBoxItem Content="🎓 Aprendiz" Tag="Aprendiz"/>
                        <ComboBoxItem Content="👁️ Visitante" Tag="Visitante"/>
                    </ComboBox>
                </Border>

                <!-- Nueva Contraseña -->
                <TextBlock Text="Nueva contraseña" 
                           FontSize="12" 
                           FontWeight="SemiBold"
                           Foreground="#333333"
                           Margin="0,0,0,8"/>

                <Border BorderThickness="2"
                        BorderBrush="#E0E0E0"
                        CornerRadius="10"
                        Background="White"
                        Margin="0,0,0,20">
                    <PasswordBox x:Name="txtNuevaPassword"
                                 FontSize="14"
                                 Padding="12,10"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 PasswordChanged="TxtNuevaPassword_PasswordChanged"/>
                </Border>

                <!-- Confirmar Contraseña -->
                <TextBlock Text="Confirmar contraseña" 
                           FontSize="12" 
                           FontWeight="SemiBold"
                           Foreground="#333333"
                           Margin="0,0,0,8"/>

                <Border BorderThickness="2"
                        BorderBrush="#E0E0E0"
                        CornerRadius="10"
                        Background="White"
                        Margin="0,0,0,15">
                    <PasswordBox x:Name="txtConfirmarPassword"
                                 FontSize="14"
                                 Padding="12,10"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 PasswordChanged="TxtConfirmarPassword_PasswordChanged"/>
                </Border>

                <!-- Indicador de fortaleza -->
                <Border x:Name="borderIndicador"
                        Height="4"
                        CornerRadius="2"
                        Background="#E0E0E0"
                        Margin="0,0,0,5"
                        Visibility="Collapsed">
                    <Border x:Name="barraFortaleza"
                            HorizontalAlignment="Left"
                            CornerRadius="2"
                            Background="#4CAF50"/>
                </Border>

                <TextBlock x:Name="txtFortaleza"
                           FontSize="11"
                           Foreground="#666666"
                           Visibility="Collapsed"
                           Margin="0,0,0,10"/>

            </StackPanel>

            <!-- Botones -->
            <Grid Grid.Row="2" Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="Cancelar"
                        Height="45"
                        Margin="0,0,5,0"
                        Background="#F5F5F5"
                        Foreground="#666666"
                        BorderThickness="0"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="BtnCancelar_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="10"
                                    x:Name="border">
                                <ContentPresenter HorizontalAlignment="Center"
                                                VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#E0E0E0"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Grid.Column="1"
                        Content="Cambiar Contraseña"
                        Height="45"
                        Margin="5,0,0,0"
                        Background="#179002"
                        Foreground="White"
                        BorderThickness="0"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="BtnCambiar_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="10"
                                    x:Name="border">
                                <ContentPresenter HorizontalAlignment="Center"
                                                VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#1FA303"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>