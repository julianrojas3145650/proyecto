<Window x:Class="Proyecto_senavicola.view.dialogs.PerfilUsuarioDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mi Perfil" 
        Height="360" 
        Width="450"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        Background="Transparent"
        AllowsTransparency="True"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#179002"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1FA303"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border CornerRadius="15" Background="White" BorderBrush="#179002" BorderThickness="2">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Cabecera -->
            <Border Grid.Row="0" Background="#179002" CornerRadius="15,15,0,0">
                <Grid>
                    <TextBlock Text="👤 Mi Perfil" 
                               FontSize="20" 
                               FontWeight="Bold" 
                               Foreground="White" 
                               VerticalAlignment="Center" 
                               Margin="20,0"/>
                    <Button Content="✕" 
                            HorizontalAlignment="Right" 
                            VerticalAlignment="Center" 
                            Width="40" 
                            Height="40" 
                            Background="Transparent" 
                            Foreground="White" 
                            BorderThickness="0" 
                            FontSize="20" 
                            Cursor="Hand" 
                            Click="BtnCerrar_Click" 
                            Margin="0,0,10,0"/>
                </Grid>
            </Border>

            <!-- Contenido -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" Margin="20">
                <StackPanel>
                    <!-- Información Personal -->
                    <TextBlock Text="Información Personal" 
                               FontSize="16" 
                               FontWeight="SemiBold" 
                               Foreground="#333" 
                               Margin="0,0,0,15"/>

                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Documento:" FontWeight="SemiBold"/>
                        <TextBlock x:Name="txtDocumento" Grid.Row="0" Grid.Column="1" Text=""/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Nombre:" FontWeight="SemiBold"/>
                        <TextBlock x:Name="txtNombre" Grid.Row="2" Grid.Column="1" Text=""/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Apellido:" FontWeight="SemiBold"/>
                        <TextBlock x:Name="txtApellido" Grid.Row="4" Grid.Column="1" Text=""/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Email:" FontWeight="SemiBold"/>
                        <TextBlock x:Name="txtEmail" Grid.Row="6" Grid.Column="1" Text=""/>

                        <TextBlock Grid.Row="8" Grid.Column="0" Text="Rol:" FontWeight="SemiBold"/>
                        <Border Grid.Row="8" Grid.Column="1" 
                                Background="#E8F5E9" 
                                CornerRadius="5" 
                                Padding="8,4" 
                                HorizontalAlignment="Left">
                            <TextBlock x:Name="txtRol" 
                                       Text="" 
                                       Foreground="#179002" 
                                       FontWeight="SemiBold"/>
                        </Border>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <!-- Pie -->
            <Border Grid.Row="2" 
                    Background="#F5F5F5" 
                    Padding="20" 
                    CornerRadius="0,0,15,15">
                <Button Content="Cerrar" 
                        Style="{StaticResource ModernButton}" 
                        Background="#666666" 
                        HorizontalAlignment="Right" 
                        Click="BtnCerrar_Click"/>
            </Border>
        </Grid>
    </Border>
</Window>