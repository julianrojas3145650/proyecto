<Window x:Class="Proyecto_senavicola.view.dialogs.RegistrarGalponDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Registrar Galpón" 
        Height="450" 
        Width="500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        Background="Transparent"
        AllowsTransparency="True"
        ResizeMode="NoResize">

    <Border CornerRadius="15" Background="White" BorderBrush="#179002" BorderThickness="2">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Cabecera -->
            <Border Grid.Row="0" Background="#179002" CornerRadius="15,15,0,0">
                <Grid>
                    <TextBlock x:Name="txtTitulo" 
                               Text="🏠 Registrar Galpón" 
                               FontSize="20" 
                               FontWeight="Bold" 
                               Foreground="White" 
                               VerticalAlignment="Center" 
                               Margin="20,0"/>
                    <Button Content="✕" 
                            HorizontalAlignment="Right" 
                            VerticalAlignment="Center" 
                            Width="40" 
                            Height="40" 
                            Background="Transparent" 
                            Foreground="White" 
                            BorderThickness="0" 
                            FontSize="20" 
                            Cursor="Hand" 
                            Click="BtnCancelar_Click" 
                            Margin="0,0,10,0"/>
                </Grid>
            </Border>

            <!-- Contenido -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="30,20">
                <StackPanel>
                    <TextBlock Text="Código del Galpón *" FontSize="12" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtCodigo" Height="35" Padding="10" Margin="0,0,0,15"/>

                    <TextBlock Text="Nombre del Galpón *" FontSize="12" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtNombre" Height="35" Padding="10" Margin="0,0,0,15"/>

                    <TextBlock Text="Longitud (metros) *" FontSize="12" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtLongitud" Height="35" Padding="10" Margin="0,0,0,15"
                             PreviewTextInput="NumericTextBox_PreviewTextInput"/>

                    <TextBlock Text="Raza Principal *" FontSize="12" Margin="0,0,0,5"/>
                    <ComboBox x:Name="cmbRaza" Height="35" Margin="0,0,0,15">
                        <ComboBoxItem Content="Rhode Island Red"/>
                        <ComboBoxItem Content="Leghorn Blanca"/>
                        <ComboBoxItem Content="Plymouth Rock"/>
                        <ComboBoxItem Content="Sussex"/>
                        <ComboBoxItem Content="Australorp"/>
                        <ComboBoxItem Content="Mixta" IsSelected="True"/>
                    </ComboBox>

                    <TextBlock Text="Ración por Ave (gramos) *" FontSize="12" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtRacion" Height="35" Padding="10" Margin="0,0,0,15"
                             Text="120"
                             PreviewTextInput="NumericTextBox_PreviewTextInput"/>

                    <Border Background="#E3F2FD" CornerRadius="8" Padding="15">
                        <StackPanel>
                            <TextBlock Text="💡 Información" 
                                       FontWeight="SemiBold" 
                                       Foreground="#2196F3" 
                                       Margin="0,0,0,5"/>
                            <TextBlock Text="El código debe ser único y no se podrá cambiar después." 
                                       TextWrapping="Wrap" 
                                       FontSize="12" 
                                       Foreground="#666"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Pie -->
            <Border Grid.Row="2" Background="#F5F5F5" Padding="20" CornerRadius="0,0,15,15">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancelar" 
                            Width="100" 
                            Height="35" 
                            Background="#666666" 
                            Foreground="White" 
                            BorderThickness="0" 
                            Cursor="Hand" 
                            Margin="0,0,10,0"
                            Click="BtnCancelar_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="8" 
                                        Padding="15,8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="btnRegistrar" 
                            Content="Registrar" 
                            Width="100" 
                            Height="35" 
                            Background="#179002" 
                            Foreground="White" 
                            BorderThickness="0" 
                            Cursor="Hand"
                            Click="BtnRegistrar_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="8" 
                                        Padding="15,8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>