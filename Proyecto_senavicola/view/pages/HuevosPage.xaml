<Page x:Class="Proyecto_senavicola.view.pages.HuevosPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:controls="clr-namespace:Proyecto_senavicola.view.controls"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1200"
      Background="#F5F5F5"
      Loaded="Page_Loaded">

    <Page.Resources>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#179002"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1FA303"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#CCCCCC"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#179002"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#179002"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F0F0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#DC3545"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C82333"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="8"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E0E0E0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                        Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#179002"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="ModernDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="AlternatingRowBackground" Value="#F9F9F9"/>
            <Setter Property="RowHeight" Value="40"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="ColumnHeaderHeight" Value="45"/>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.1" BlurRadius="10" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Estilo para las filas del panel de visión ── -->
        <Style x:Key="VisionLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>
        <Style x:Key="VisionValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <controls:NavBarControl x:Name="navBar" Grid.Row="0"/>

        <Border Grid.Row="1" Padding="20">
            <ScrollViewer VerticalScrollBarVisibility="Hidden" 
                          HorizontalScrollBarVisibility="Disabled">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- ── Tarjetas de estadísticas ── -->
                    <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="#E8F5E9" CornerRadius="8" Padding="15" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="📦 Total Inventario" FontSize="12" Foreground="#666666"/>
                                    <TextBlock x:Name="txtTotalInventario" Text="0" FontSize="28" FontWeight="Bold" 
                                               Foreground="#179002" Margin="0,5,0,0"/>
                                    <TextBlock Text="huevos disponibles" FontSize="10" Foreground="#666666"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Background="#E3F2FD" CornerRadius="8" Padding="15" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="💰 Vendidos Hoy" FontSize="12" Foreground="#666666"/>
                                    <TextBlock x:Name="txtVendidosHoy" Text="0" FontSize="28" FontWeight="Bold" 
                                               Foreground="#2196F3" Margin="0,5,0,0"/>
                                    <TextBlock Text="huevos vendidos" FontSize="10" Foreground="#666666"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Background="#FFEBEE" CornerRadius="8" Padding="15" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="❌ Dañados" FontSize="12" Foreground="#666666"/>
                                    <TextBlock x:Name="txtDanados" Text="0" FontSize="28" FontWeight="Bold" 
                                               Foreground="#F44336" Margin="0,5,0,0"/>
                                    <TextBlock Text="huevos dañados" FontSize="10" Foreground="#666666"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="3" Background="#FFF3E0" CornerRadius="8" Padding="15" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="⭐ Más Común" FontSize="12" Foreground="#666666"/>
                                    <TextBlock x:Name="txtTipoComun" Text="AAA" FontSize="28" FontWeight="Bold" 
                                               Foreground="#FF9800" Margin="0,5,0,0"/>
                                    <TextBlock Text="tipo dominante" FontSize="10" Foreground="#666666"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="4" Background="#F3E5F5" CornerRadius="8" Padding="15">
                                <StackPanel>
                                    <TextBlock Text="⚖️ Peso Promedio" FontSize="12" Foreground="#666666"/>
                                    <TextBlock x:Name="txtPesoPromedio" Text="0g" FontSize="28" FontWeight="Bold" 
                                               Foreground="#9C27B0" Margin="0,5,0,0"/>
                                    <TextBlock Text="peso medio" FontSize="10" Foreground="#666666"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- ── TabControl superior (Clasificación Manual / Automática) ── -->
                    <TabControl Grid.Row="2" Margin="0,0,0,20" Background="Transparent" BorderThickness="0">
                        <TabControl.Resources>
                            <Style TargetType="TabItem">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TabItem">
                                            <Border Name="Border" Background="White" BorderBrush="#E0E0E0" 
                                                    BorderThickness="1,1,1,0" CornerRadius="10,10,0,0" 
                                                    Padding="20,12" Margin="0,0,5,0">
                                                <ContentPresenter x:Name="ContentSite" ContentSource="Header" 
                                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#179002"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="False">
                                                    <Setter Property="Foreground" Value="#666666"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#F0F0F0"/>
                                                </Trigger>
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="IsMouseOver" Value="True"/>
                                                        <Condition Property="IsSelected" Value="True"/>
                                                    </MultiTrigger.Conditions>
                                                    <Setter TargetName="Border" Property="Background" Value="#1FA303"/>
                                                </MultiTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TabControl.Resources>

                        <!-- ════════════════════════════════════════════ -->
                        <!--  PESTAÑA 1: CLASIFICACIÓN MANUAL            -->
                        <!-- ════════════════════════════════════════════ -->
                        <TabItem Header="🥚 Clasificación Manual" FontSize="14" FontWeight="SemiBold">
                            <Border Style="{StaticResource CardStyle}" BorderThickness="1,0,1,1" 
                                    BorderBrush="#E0E0E0" CornerRadius="0,10,10,10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0" Margin="0,0,0,20">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0" Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                                <Border Background="LightGray" CornerRadius="5" Margin="0,0,0,20">
                                                    <TextBlock Text="Galpón/Lote de Aves 🐔" FontSize="15" 
                                                               FontWeight="SemiBold" Margin="20,0,0,0"/>
                                                </Border>
                                                <ComboBox x:Name="cmbLoteAves" Style="{StaticResource ModernComboBox}"
                                                          SelectionChanged="CmbLoteAves_SelectionChanged">
                                                    <ComboBoxItem Content="Seleccionar galpón..." IsSelected="True" IsEnabled="False"/>
                                                </ComboBox>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                                <Border CornerRadius="5" Background="LightGray" Margin="0,0,0,10">
                                                    <TextBlock Text="Cantidad de Huevos" FontSize="15" 
                                                               FontWeight="SemiBold" Margin="20,0,0,0"/>
                                                </Border>
                                                <TextBox x:Name="txtCantidad" Style="{StaticResource ModernTextBox}" 
                                                         Text="1" PreviewTextInput="NumericTextBox_PreviewTextInput"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2">
                                                <Border Background="LightGray" CornerRadius="5" Margin="0,0,0,10">
                                                    <TextBlock Text="Peso (gramos)" FontWeight="SemiBold" Margin="20,0,0,0"/>
                                                </Border>
                                                <Grid>
                                                    <TextBox x:Name="txtPeso" Style="{StaticResource ModernTextBox}" 
                                                             PreviewTextInput="NumericTextBox_PreviewTextInput"
                                                             TextChanged="TxtPeso_TextChanged"/>
                                                    <TextBlock x:Name="txtTipoDetectado" Text="" 
                                                               HorizontalAlignment="Right" VerticalAlignment="Center" 
                                                               Margin="0,0,10,0" Foreground="#179002" FontWeight="Bold"/>
                                                </Grid>
                                            </StackPanel>
                                        </Grid>

                                        <Grid Grid.Row="1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border x:Name="borderInfoLote" Grid.Column="0" Background="#E8F5E9" 
                                                    CornerRadius="8" Padding="15" Margin="0,0,10,0" 
                                                    Visibility="Collapsed">
                                                <StackPanel>
                                                    <TextBlock Text="📋 Información del Galpón" FontWeight="SemiBold" 
                                                               Foreground="#179002" Margin="0,0,0,5"/>
                                                    <TextBlock x:Name="txtInfoLote" Text="" TextWrapping="Wrap" 
                                                               FontSize="12" Foreground="#666666"/>
                                                </StackPanel>
                                            </Border>

                                            <Button Grid.Column="1" Content="➕ Registrar Huevo" 
                                                    Style="{StaticResource PrimaryButtonStyle}" 
                                                    VerticalAlignment="Bottom" Click="AgregarHuevo_Click"
                                                    Height="45" Padding="25,10"/>
                                        </Grid>
                                    </Grid>

                                    <Border Grid.Row="1" Background="LightGray" CornerRadius="8" Padding="15">
                                        <StackPanel>
                                            <TextBlock Text="📋 Tabla de Clasificación por Peso" FontSize="14" 
                                                       FontWeight="SemiBold" Margin="0,0,0,10"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Background="#FFC000" CornerRadius="5" Padding="10" Margin="2">
                                                    <StackPanel>
                                                        <TextBlock Text="Jumbo" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                        <TextBlock Text="&gt; 78g" HorizontalAlignment="Center" FontSize="12"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border Grid.Column="1" Background="#FFD45C" CornerRadius="5" Padding="10" Margin="2">
                                                    <StackPanel>
                                                        <TextBlock Text="AAA" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                        <TextBlock Text="67-77g" HorizontalAlignment="Center" FontSize="12"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border Grid.Column="2" Background="#FAE669" CornerRadius="5" Padding="10" Margin="2">
                                                    <StackPanel>
                                                        <TextBlock Text="AA" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                        <TextBlock Text="60-66g" HorizontalAlignment="Center" FontSize="12"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border Grid.Column="3" Background="#BDBDBD" CornerRadius="5" Padding="10" Margin="2">
                                                    <StackPanel>
                                                        <TextBlock Text="A" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                        <TextBlock Text="53-59g" HorizontalAlignment="Center" FontSize="12"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border Grid.Column="4" Background="#E0E0E0" CornerRadius="5" Padding="10" Margin="2">
                                                    <StackPanel>
                                                        <TextBlock Text="B" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                        <TextBlock Text="46-52g" HorizontalAlignment="Center" FontSize="12"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border Grid.Column="5" Background="#707070" CornerRadius="5" Padding="10" Margin="2">
                                                    <StackPanel>
                                                        <TextBlock Text="C" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                        <TextBlock Text="Menor a 46g" HorizontalAlignment="Center" FontSize="12"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </TabItem>

                        <!-- ════════════════════════════════════════════ -->
                        <!--  PESTAÑA 2: CLASIFICACIÓN AUTOMÁTICA        -->
                        <!--  (integración visión por computador)        -->
                        <!-- ════════════════════════════════════════════ -->
                        <TabItem Header="🤖 Clasificación Automática" FontSize="14" FontWeight="SemiBold">
                            <Border Style="{StaticResource CardStyle}" BorderThickness="1,0,1,1" 
                                    BorderBrush="#E0E0E0" CornerRadius="0,10,10,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <!-- Cámara -->
                                        <ColumnDefinition Width="2.2*"/>
                                        <!-- Panel derecho -->
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- ── COLUMNA IZQUIERDA: Cámara ── -->
                                    <Grid Grid.Column="0" Margin="0,0,16,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <!-- Video -->
                                            <RowDefinition Height="Auto"/>
                                            <!-- Panel CV -->
                                        </Grid.RowDefinitions>

                                        <!-- Video feed -->
                                        <Border Grid.Row="0" Background="#000000" CornerRadius="10" Height="400">
                                            <Grid>
                                                <Border x:Name="borderCamera" Background="#1A1A1A" CornerRadius="10">
                                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                        <TextBlock Text="📷" FontSize="80" HorizontalAlignment="Center" 
                                                                   Foreground="White" Margin="0,0,0,20"/>
                                                        <TextBlock Text="Cámara Desactivada" FontSize="18" 
                                                                   Foreground="White" HorizontalAlignment="Center"/>
                                                        <TextBlock Text="Presiona 'Activar Cámara' para comenzar" 
                                                                   FontSize="12" Foreground="#CCCCCC" 
                                                                   HorizontalAlignment="Center" Margin="0,10,0,0"/>
                                                    </StackPanel>
                                                </Border>

                                                
                                            </Grid>
                                        </Border>

                                        <!-- ── PANEL DE VISIÓN POR COMPUTADOR ── -->
                                        <Border Grid.Row="1" Background="#1E1E2E" CornerRadius="10" 
                                                Padding="16" Margin="0,12,0,0">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <!-- Encabezado -->
                                                <Grid Grid.Row="0" Margin="0,0,0,12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                        <TextBlock Text="🔬" FontSize="16" VerticalAlignment="Center" 
                                                                   Margin="0,0,8,0"/>
                                                        <TextBlock Text="VISIÓN POR COMPUTADOR" FontSize="13" 
                                                                   FontWeight="Bold" Foreground="#00D4AA" 
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <!-- Indicador de huevo detectado -->
                                                    <Border Grid.Column="1" x:Name="borderEstadoCV"
                                                            Background="#2D2D3F" CornerRadius="12" Padding="10,4">
                                                        <TextBlock x:Name="txtEstadoCV" Text="⬤  Sin huevo" 
                                                                   FontSize="11" Foreground="#FF6B6B" 
                                                                   FontWeight="SemiBold"/>
                                                    </Border>
                                                </Grid>

                                                <!-- Métricas principales (fila de tarjetas) -->
                                                <Grid Grid.Row="1" Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Diámetro -->
                                                    <Border Grid.Column="0" Background="#252535" CornerRadius="8" 
                                                            Padding="12,10" Margin="0,0,6,0">
                                                        <StackPanel>
                                                            <TextBlock Text="DIÁMETRO" Style="{StaticResource VisionLabelStyle}"/>
                                                            <TextBlock x:Name="txtVisionDiametro" Text="-- cm" 
                                                                       Style="{StaticResource VisionValueStyle}" 
                                                                       Foreground="#00D4AA"/>
                                                            <TextBlock Text="eje menor" FontSize="9" Foreground="#666688"/>
                                                        </StackPanel>
                                                    </Border>

                                                    <!-- Largo -->
                                                    <Border Grid.Column="1" Background="#252535" CornerRadius="8" 
                                                            Padding="12,10" Margin="0,0,6,0">
                                                        <StackPanel>
                                                            <TextBlock Text="LARGO" Style="{StaticResource VisionLabelStyle}"/>
                                                            <TextBlock x:Name="txtVisionLargo" Text="-- cm" 
                                                                       Style="{StaticResource VisionValueStyle}" 
                                                                       Foreground="#7EC8E3"/>
                                                            <TextBlock Text="eje mayor" FontSize="9" Foreground="#666688"/>
                                                        </StackPanel>
                                                    </Border>

                                                    <!-- Volumen -->
                                                    <Border Grid.Column="2" Background="#252535" CornerRadius="8" 
                                                            Padding="12,10" Margin="0,0,6,0">
                                                        <StackPanel>
                                                            <TextBlock Text="VOLUMEN" Style="{StaticResource VisionLabelStyle}"/>
                                                            <TextBlock x:Name="txtVisionVolumen" Text="-- cm³" 
                                                                       Style="{StaticResource VisionValueStyle}" 
                                                                       Foreground="#FFD700"/>
                                                            <TextBlock Text="elipsoide" FontSize="9" Foreground="#666688"/>
                                                        </StackPanel>
                                                    </Border>

                                                    <!-- Cuadros / Escala -->
                                                    <Border Grid.Column="3" Background="#252535" CornerRadius="8" 
                                                            Padding="12,10">
                                                        <StackPanel>
                                                            <TextBlock Text="ESCALA" Style="{StaticResource VisionLabelStyle}"/>
                                                            <TextBlock x:Name="txtVisionEscala" Text="-- px/cm" 
                                                                       Style="{StaticResource VisionValueStyle}" 
                                                                       Foreground="#C8A4FF"/>
                                                            <TextBlock x:Name="txtVisionCuadros" Text="-- cuadros" 
                                                                       FontSize="9" Foreground="#666688"/>
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>

                                                <!-- Fila OCR -->
                                                <Border Grid.Row="2" Background="#252535" CornerRadius="8" Padding="12,8">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="OCR " FontSize="11" 
                                                                   FontWeight="Bold" Foreground="#AAAAAA" 
                                                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                        <TextBlock x:Name="txtVisionOCR" Grid.Column="1" 
                                                                   Text="Sin texto detectado" FontSize="11" 
                                                                   Foreground="#888888" VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </Grid>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </Grid>

                                    <!-- ── COLUMNA DERECHA: Controles ── -->
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="⚙️ Controles" FontSize="18" FontWeight="Bold" 
                                                   Foreground="#179002" Margin="0,0,0,20"/>

                                        <!-- Estado de dispositivos -->
                                        <Border Background="Gray" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                                            <StackPanel>
                                                <TextBlock Text="Estado de Dispositivos" FontWeight="SemiBold" 
                                                           Margin="0,0,0,10"/>
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="📷 Cámara" VerticalAlignment="Center"/>
                                                    <Ellipse x:Name="statusCamera" Grid.Column="1" 
                                                             Width="12" Height="12" Fill="#DC3545"/>
                                                </Grid>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="🔬 Visión CV" VerticalAlignment="Center"/>
                                                    <Ellipse x:Name="statusCV" Grid.Column="1" 
                                                             Width="12" Height="12" Fill="#DC3545"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <Button Content="📷 Activar Cámara" Style="{StaticResource PrimaryButtonStyle}" 
                                                Margin="0,0,0,10" Click="ActivarCamara_Click" x:Name="btnActivarCamara"/>

                                        <Button Content="⚖ Capturar Peso" Style="{StaticResource PrimaryButtonStyle}" 
                                                Margin="0,0,0,10"/>

                                        <!-- Lectura de gramera -->
                                        <Border Background="#75E05A" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                                            <StackPanel>
                                                <TextBlock Text="⚖️ Lectura Actual" FontWeight="SemiBold" 
                                                           Margin="0,0,0,10"/>
                                                <TextBlock x:Name="txtLecturaGramera" Text="0.0 g" FontSize="32" 
                                                           FontWeight="Bold" Foreground="#179002" 
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock x:Name="txtTipoAutomatico" Text="---" FontSize="16" 
                                                           Foreground="#666666" HorizontalAlignment="Center" 
                                                           Margin="0,5,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Botón registrar huevo automático -->
                                        <Button Content="✅ Registrar Huevo Detectado" 
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                Margin="0,0,0,10" 
                                                Click="IniciarDeteccion_Click"
                                                Height="50" FontSize="13"/>

                                        <!-- Resumen rápido CV (mini panel) -->
                                        <Border Background="#1E1E2E" CornerRadius="8" Padding="12" Margin="0,5,0,0">
                                            <StackPanel>
                                                <TextBlock Text="Último huevo medido" FontSize="10" 
                                                           Foreground="#888888" Margin="0,0,0,8"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Vol." FontSize="10" Foreground="#AAAAAA"/>
                                                        <TextBlock x:Name="txtResumenVolumen" Text="--" 
                                                                   FontSize="13" FontWeight="Bold" 
                                                                   Foreground="#FFD700"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="Diám." FontSize="10" Foreground="#AAAAAA"/>
                                                        <TextBlock x:Name="txtResumenDiametro" Text="--" 
                                                                   FontSize="13" FontWeight="Bold" 
                                                                   Foreground="#00D4AA"/>
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </TabItem>
                    </TabControl>

                    <!-- ── TabControl inferior (Inventario, Vendidos, etc.) ── -->
                    <Grid Grid.Row="3">
                        <TabControl Background="Transparent" BorderThickness="0">
                            <TabControl.Resources>
                                <Style TargetType="TabItem">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TabItem">
                                                <Border Name="Border" Background="White" BorderBrush="#E0E0E0" 
                                                        BorderThickness="1,1,1,0" CornerRadius="10,10,0,0" 
                                                        Padding="15,10" Margin="0,0,5,0">
                                                    <ContentPresenter x:Name="ContentSite" ContentSource="Header" 
                                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="#179002"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="False">
                                                        <Setter Property="Foreground" Value="#666666"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="#F0F0F0"/>
                                                    </Trigger>
                                                    <MultiTrigger>
                                                        <MultiTrigger.Conditions>
                                                            <Condition Property="IsMouseOver" Value="True"/>
                                                            <Condition Property="IsSelected" Value="True"/>
                                                        </MultiTrigger.Conditions>
                                                        <Setter TargetName="Border" Property="Background" Value="#1FA303"/>
                                                    </MultiTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TabControl.Resources>

                            <TabItem Header="📦 Inventario Disponible" FontSize="14">
                                <Border Style="{StaticResource CardStyle}" BorderThickness="1,0,1,1" 
                                        BorderBrush="#E0E0E0" CornerRadius="0,10,10,10">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0" Margin="0,0,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="txtBuscarInventario" Grid.Column="0" 
                                                     Style="{StaticResource ModernTextBox}" 
                                                     TextChanged="TxtBuscar_TextChanged"
                                                     Tag="🔍 Buscar por tipo o fecha"/>
                                            <ComboBox x:Name="cmbFiltroTipo" Grid.Column="1" 
                                                      Style="{StaticResource ModernComboBox}"
                                                      Width="150" Margin="10,0,10,0"
                                                      SelectionChanged="CmbFiltro_SelectionChanged">
                                                <ComboBoxItem Content="Todos los tipos" IsSelected="True"/>
                                                <ComboBoxItem Content="Jumbo"/>
                                                <ComboBoxItem Content="AAA"/>
                                                <ComboBoxItem Content="AA"/>
                                                <ComboBoxItem Content="A"/>
                                                <ComboBoxItem Content="B"/>
                                                <ComboBoxItem Content="C"/>
                                            </ComboBox>
                                            <DatePicker x:Name="dpFiltroFecha" Grid.Column="2" 
                                                        Width="150" SelectedDateChanged="DpFiltroFecha_SelectedDateChanged"/>
                                        </Grid>

                                        <DataGrid x:Name="dgInventario" Grid.Row="1" Style="{StaticResource ModernDataGrid}">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Tipo 🥚" Binding="{Binding Tipo}" Width="100"/>
                                                <DataGridTextColumn Header="Cantidad" Binding="{Binding Cantidad}" Width="100"/>
                                                <DataGridTextColumn Header="Peso Promedio" Binding="{Binding PesoPromedio, StringFormat={}{0:F2} g}" Width="130"/>
                                                <DataGridTextColumn Header="Fecha Ingreso" Binding="{Binding FechaIngreso, StringFormat=dd/MM/yyyy HH:mm}" Width="150"/>
                                                <DataGridTextColumn Header="Lote Huevos" Binding="{Binding Lote}" Width="120"/>
                                                <DataGridTextColumn Header="Galpón 🐔" Binding="{Binding LoteAvesCodigo}" Width="100"/>
                                                <DataGridTemplateColumn Header="Acciones" Width="*">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                                <Button Content="✏️" ToolTip="Editar" 
                                                                        Style="{StaticResource IconButtonStyle}"
                                                                        Click="EditarHuevo_Click" Tag="{Binding}"/>
                                                                <Button Content="🗑️" ToolTip="Eliminar" 
                                                                        Style="{StaticResource IconButtonStyle}"
                                                                        Click="EliminarHuevo_Click" Tag="{Binding}" 
                                                                        Margin="5,0,0,0"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>

                                        <Border Grid.Row="2" Background="#F9F9F9" CornerRadius="8" 
                                                Padding="15" Margin="0,15,0,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                    <TextBlock Text="Totales por tipo: " FontWeight="SemiBold" 
                                                               VerticalAlignment="Center" Margin="0,0,15,0"/>
                                                    <TextBlock x:Name="txtTotalJumbo" Text="Jumbo: 0" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="txtTotalAAA"   Text="AAA: 0"   Margin="0,0,15,0" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="txtTotalAA"    Text="AA: 0"    Margin="0,0,15,0" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="txtTotalA"     Text="A: 0"     Margin="0,0,15,0" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="txtTotalB"     Text="B: 0"     Margin="0,0,15,0" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="txtTotalC"     Text="C: 0"     VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <TextBlock x:Name="txtTotalGeneral" Grid.Column="1" 
                                                           Text="Total General: 0 huevos" FontWeight="Bold" FontSize="16" 
                                                           Foreground="#179002" HorizontalAlignment="Right" 
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Border>
                            </TabItem>

                            <TabItem Header="💰 Huevos Vendidos" FontSize="14">
                                <Border Style="{StaticResource CardStyle}" BorderThickness="1,0,1,1" 
                                        BorderBrush="#E0E0E0" CornerRadius="0,10,10,10">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid Grid.Row="0" Margin="0,0,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="txtBuscarVendidos" Grid.Column="0" 
                                                     Style="{StaticResource ModernTextBox}" 
                                                     TextChanged="TxtBuscarVendidos_TextChanged"
                                                     Tag="🔍 Buscar en vendidos"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="10,0,0,0">
                                                <DatePicker x:Name="dpFiltroVendidosInicio" Width="130" Margin="0,0,10,0"/>
                                                <TextBlock Text="a" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                <DatePicker x:Name="dpFiltroVendidosFin" Width="130"/>
                                            </StackPanel>
                                        </Grid>
                                        <DataGrid x:Name="dgVendidos" Grid.Row="1" Style="{StaticResource ModernDataGrid}">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Tipo 🥚" Binding="{Binding Tipo}" Width="100"/>
                                                <DataGridTextColumn Header="Cantidad" Binding="{Binding Cantidad}" Width="100"/>
                                                <DataGridTextColumn Header="Precio Unitario" Binding="{Binding PrecioUnitario, StringFormat=C}" Width="120"/>
                                                <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat=C}" Width="120"/>
                                                <DataGridTextColumn Header="Fecha Venta" Binding="{Binding FechaVenta, StringFormat=dd/MM/yyyy HH:mm}" Width="150"/>
                                                <DataGridTextColumn Header="Cliente" Binding="{Binding Cliente}" Width="*"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                        <Border Grid.Row="2" Background="#05C9FF" CornerRadius="8" Padding="15" Margin="0,15,0,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                    <TextBlock Text="Total Vendidos: " FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="txtTotalVendidosCantidad" Text="0 huevos" 
                                                               FontWeight="Bold" Margin="5,0,0,0" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <TextBlock x:Name="txtTotalVendidosValor" Grid.Column="1" 
                                                           Text="Total: $0.00" FontWeight="Bold" FontSize="16" 
                                                           Foreground="#0003C9" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Border>
                            </TabItem>

                            <TabItem Header="❌ Huevos Dañados" FontSize="14">
                                <Border Style="{StaticResource CardStyle}" BorderThickness="1,0,1,1" 
                                        BorderBrush="#E0E0E0" CornerRadius="0,10,10,10">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid Grid.Row="0" Margin="0,0,0,15">
                                            <TextBox x:Name="txtBuscarDanados" Style="{StaticResource ModernTextBox}" 
                                                     TextChanged="TxtBuscarDanados_TextChanged"
                                                     Tag="🔍 Buscar en dañados"/>
                                        </Grid>
                                        <DataGrid x:Name="dgDanados" Grid.Row="1" Style="{StaticResource ModernDataGrid}">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Tipo 🥚" Binding="{Binding Tipo}" Width="100"/>
                                                <DataGridTextColumn Header="Cantidad" Binding="{Binding Cantidad}" Width="100"/>
                                                <DataGridTextColumn Header="Motivo" Binding="{Binding Motivo}" Width="200"/>
                                                <DataGridTextColumn Header="Fecha Registro" Binding="{Binding FechaRegistro, StringFormat=dd/MM/yyyy HH:mm}" Width="150"/>
                                                <DataGridTextColumn Header="Observaciones" Binding="{Binding Observaciones}" Width="*"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                        <Border Grid.Row="2" Background="#FFB5B5" CornerRadius="8" Padding="15" Margin="0,15,0,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Total Dañados: " FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                <TextBlock x:Name="txtTotalDanados" Text="0 huevos" FontWeight="Bold" FontSize="16" 
                                                           Foreground="#F44336" Margin="5,0,0,0" VerticalAlignment="Center"/>
                                                <TextBlock x:Name="txtPorcentajeDanados" Text="(0%)" FontSize="14" 
                                                           Foreground="#666666" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>
                            </TabItem>

                            <TabItem Header="📜 Historial" FontSize="14">
                                <Border Style="{StaticResource CardStyle}" BorderThickness="1,0,1,1" 
                                        BorderBrush="#E0E0E0" CornerRadius="0,10,10,10">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Grid Grid.Row="0" Margin="0,0,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="txtBuscarHistorial" Grid.Column="0" 
                                                     Style="{StaticResource ModernTextBox}" 
                                                     Tag="🔍 Buscar en historial"/>
                                            <ComboBox x:Name="cmbFiltroAccion" Grid.Column="1" 
                                                      Style="{StaticResource ModernComboBox}"
                                                      Width="200" Margin="10,0,0,0">
                                                <ComboBoxItem Content="Todas las acciones" IsSelected="True"/>
                                                <ComboBoxItem Content="Ingreso Manual"/>
                                                <ComboBoxItem Content="Ingreso Automático"/>
                                                <ComboBoxItem Content="Venta"/>
                                                <ComboBoxItem Content="Daño"/>
                                                <ComboBoxItem Content="Edición"/>
                                            </ComboBox>
                                        </Grid>
                                        <DataGrid x:Name="dgHistorial" Grid.Row="1" Style="{StaticResource ModernDataGrid}">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Fecha/Hora" Binding="{Binding Fecha, StringFormat=dd/MM/yyyy HH:mm:ss}" Width="150"/>
                                                <DataGridTextColumn Header="Acción" Binding="{Binding Accion}" Width="150"/>
                                                <DataGridTextColumn Header="Tipo" Binding="{Binding Tipo}" Width="80"/>
                                                <DataGridTextColumn Header="Cantidad" Binding="{Binding Cantidad}" Width="80"/>
                                                <DataGridTextColumn Header="Usuario" Binding="{Binding Usuario}" Width="120"/>
                                                <DataGridTextColumn Header="Detalles" Binding="{Binding Detalles}" Width="*"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </Border>
                            </TabItem>

                            <TabItem Header="🏠 Producción por Galpón" FontSize="14">
                                <Border Style="{StaticResource CardStyle}" BorderThickness="1,0,1,1" 
                                        BorderBrush="#E0E0E0" CornerRadius="0,10,10,10">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="📊 Resumen de Producción por Galpón" 
                                                   FontSize="16" FontWeight="Bold" Foreground="#179002" Margin="0,0,0,15"/>
                                        <DataGrid x:Name="dgProduccionGalpon" Grid.Row="1" Style="{StaticResource ModernDataGrid}">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Galpón" Binding="{Binding CodigoLote}" Width="120"/>
                                                <DataGridTextColumn Header="Raza" Binding="{Binding Raza}" Width="150"/>
                                                <DataGridTextColumn Header="Total Huevos" Binding="{Binding TotalHuevos}" Width="120"/>
                                                <DataGridTextColumn Header="Jumbo" Binding="{Binding CantidadJumbo}" Width="80"/>
                                                <DataGridTextColumn Header="AAA" Binding="{Binding CantidadAAA}" Width="80"/>
                                                <DataGridTextColumn Header="AA" Binding="{Binding CantidadAA}" Width="80"/>
                                                <DataGridTextColumn Header="A" Binding="{Binding CantidadA}" Width="80"/>
                                                <DataGridTextColumn Header="B" Binding="{Binding CantidadB}" Width="80"/>
                                                <DataGridTextColumn Header="C" Binding="{Binding CantidadC}" Width="80"/>
                                                <DataGridTextColumn Header="Promedio Peso" Binding="{Binding PesoPromedio, StringFormat={}{0:F2}g}" Width="120"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </Border>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
