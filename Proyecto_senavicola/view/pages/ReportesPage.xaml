<Page x:Class="Proyecto_senavicola.view.pages.ReportesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:Proyecto_senavicola.view.controls"
      Title="Reportes"
      Background="#F5F5F5"
      Loaded="Page_Loaded">
    <Page.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ReportButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#179002"/>
                    <Setter Property="Background" Value="#F0F0F0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- NavBar -->
        <controls:NavBarControl x:Name="navBar" Grid.Row="0"/>

        <!-- Contenido Principal -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" Margin="20">
            <StackPanel>

                <!-- Grid de Reportes -->
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Reporte de Gallinas -->
                    <Button Grid.Row="0" Grid.Column="0" Style="{StaticResource ReportButtonStyle}"
                            Click="BtnReporteGallinas_Click">
                        <StackPanel>
                            <TextBlock Text="🐔" FontSize="48" HorizontalAlignment="Center"/>
                            <TextBlock Text="Reporte de Gallinas" 
                                       FontSize="16" FontWeight="SemiBold" 
                                       HorizontalAlignment="Center" Margin="0,10,0,0"/>
                            <TextBlock Text="Galpones, lotes y asignaciones" 
                                       FontSize="12" Foreground="#666666" 
                                       HorizontalAlignment="Center" TextWrapping="Wrap"
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Reporte de Huevos -->
                    <Button Grid.Row="0" Grid.Column="1" Style="{StaticResource ReportButtonStyle}"
                            Click="BtnReporteHuevos_Click">
                        <StackPanel>
                            <TextBlock Text="🥚" FontSize="48" HorizontalAlignment="Center"/>
                            <TextBlock Text="Reporte de Huevos" 
                                       FontSize="16" FontWeight="SemiBold" 
                                       HorizontalAlignment="Center" Margin="0,10,0,0"/>
                            <TextBlock Text="Inventario, ventas y dañados" 
                                       FontSize="12" Foreground="#666666" 
                                       HorizontalAlignment="Center" TextWrapping="Wrap"
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Reporte de Insumos -->
                    <Button Grid.Row="0" Grid.Column="2" Style="{StaticResource ReportButtonStyle}"
                            Click="BtnReporteInsumos_Click">
                        <StackPanel>
                            <TextBlock Text="📦" FontSize="48" HorizontalAlignment="Center"/>
                            <TextBlock Text="Reporte de Insumos" 
                                       FontSize="16" FontWeight="SemiBold" 
                                       HorizontalAlignment="Center" Margin="0,10,0,0"/>
                            <TextBlock Text="Inventario y movimientos" 
                                       FontSize="12" Foreground="#666666" 
                                       HorizontalAlignment="Center" TextWrapping="Wrap"
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Reporte de Producción -->
                    <Button Grid.Row="1" Grid.Column="0" Style="{StaticResource ReportButtonStyle}"
                            Click="BtnReporteProduccion_Click">
                        <StackPanel>
                            <TextBlock Text="📈" FontSize="48" HorizontalAlignment="Center"/>
                            <TextBlock Text="Reporte de Producción" 
                                       FontSize="16" FontWeight="SemiBold" 
                                       HorizontalAlignment="Center" Margin="0,10,0,0"/>
                            <TextBlock Text="Producción por galpón" 
                                       FontSize="12" Foreground="#666666" 
                                       HorizontalAlignment="Center" TextWrapping="Wrap"
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Reporte Financiero -->
                    <Button Grid.Row="1" Grid.Column="1" Style="{StaticResource ReportButtonStyle}"
                            Click="BtnReporteFinanciero_Click">
                        <StackPanel>
                            <TextBlock Text="💰" FontSize="48" HorizontalAlignment="Center"/>
                            <TextBlock Text="Reporte Financiero" 
                                       FontSize="16" FontWeight="SemiBold" 
                                       HorizontalAlignment="Center" Margin="0,10,0,0"/>
                            <TextBlock Text="Ventas e ingresos" 
                                       FontSize="12" Foreground="#666666" 
                                       HorizontalAlignment="Center" TextWrapping="Wrap"
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Historial General -->
                    <Button Grid.Row="1" Grid.Column="2" Style="{StaticResource ReportButtonStyle}"
                            Click="BtnHistorialGeneral_Click">
                        <StackPanel>
                            <TextBlock Text="📜" FontSize="48" HorizontalAlignment="Center"/>
                            <TextBlock Text="Historial General" 
                                       FontSize="16" FontWeight="SemiBold" 
                                       HorizontalAlignment="Center" Margin="0,10,0,0"/>
                            <TextBlock Text="Todas las operaciones" 
                                       FontSize="12" Foreground="#666666" 
                                       HorizontalAlignment="Center" TextWrapping="Wrap"
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>