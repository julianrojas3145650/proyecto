<Page x:Class="Proyecto_senavicola.view.pages.ConfiguracionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:Proyecto_senavicola.view.controls"
      Title="Configuración"
      Background="#F5F5F5"
      Loaded="Page_Loaded">

    <Page.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="25"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ConfigButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="140"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#179002"/>
                    <Setter Property="Background" Value="#F0FFF0"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#179002"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="10" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1FA303"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- NavBar -->
        <controls:NavBarControl x:Name="navBar" Grid.Row="0"/>

        <!-- Contenido Principal -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="20">
            <StackPanel>

                <!-- Opciones de Configuración -->
                <TextBlock Text="Opciones de Configuración" 
                           FontSize="20" 
                           FontWeight="SemiBold" 
                           Margin="15,20,0,10"/>

                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Gestión de Usuarios -->
                    <Button Grid.Row="0" Grid.Column="0" 
                            x:Name="btnCambiarContraseñas"
                            Style="{StaticResource ConfigButtonStyle}"
                            Click="BtnGestionUsuarios_Click"
                            Padding="10">
                        <StackPanel>
                            <TextBlock Text="🔐" 
                                       FontSize="40" 
                                       HorizontalAlignment="Center" 
                                       Margin="0,0,0,10"/>
                            <TextBlock Text="Gestión de Usuarios" 
                                       FontSize="16" 
                                       FontWeight="Bold" 
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="Crear, editar y/o eliminar usuarios" 
                                       FontSize="12" 
                                       Foreground="#666666" 
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap"
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Backup Base de Datos -->
                    <Button Grid.Row="0" Grid.Column="1" 
                            Style="{StaticResource ConfigButtonStyle}"
                            Click="BtnBackupDB_Click"
                            Padding="10">
                        <StackPanel>
                            <TextBlock Text="💾" 
                                       FontSize="40" 
                                       HorizontalAlignment="Center" 
                                       Margin="0,0,0,10"/>
                            <TextBlock Text="Respaldar Base de Datos" 
                                       FontSize="16" 
                                       FontWeight="Bold" 
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="Crear copia de seguridad" 
                                       FontSize="12" 
                                       Foreground="#666666" 
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap"
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Restaurar Base de Datos -->
                    <Button Grid.Row="0" Grid.Column="2" 
                            x:Name="btnRestaurarDB"
                            Style="{StaticResource ConfigButtonStyle}"
                            Click="BtnRestaurarDB_Click"
                            Padding="10">
                        <StackPanel>
                            <TextBlock Text="📥" 
                                       FontSize="40" 
                                       HorizontalAlignment="Center" 
                                       Margin="0,0,0,10"/>
                            <TextBlock Text="Restaurar Base de Datos" 
                                       FontSize="16" 
                                       FontWeight="Bold" 
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="Restaurar desde respaldo" 
                                       FontSize="12" 
                                       Foreground="#666666" 
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap"
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Limpiar Historial -->
                    <Button Grid.Row="1" Grid.Column="0" 
                            x:Name="btnLimpiarHistorial"
                            Style="{StaticResource ConfigButtonStyle}"
                            Click="BtnLimpiarHistorial_Click"
                            Padding="10">
                        <StackPanel>
                            <TextBlock Text="🗑️" 
                                       FontSize="40" 
                                       HorizontalAlignment="Center" 
                                       Margin="0,0,0,10"/>
                            <TextBlock Text="Limpiar Historial" 
                                       FontSize="16" 
                                       FontWeight="Bold" 
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="Eliminar registros antiguos" 
                                       FontSize="12" 
                                       Foreground="#666666" 
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap"
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Información del Sistema -->
                    <Button Grid.Row="1" Grid.Column="1" 
                            Style="{StaticResource ConfigButtonStyle}"
                            Click="BtnInfoSistema_Click"
                            Padding="10">
                        <StackPanel>
                            <TextBlock Text="ℹ️" 
                                       FontSize="40" 
                                       HorizontalAlignment="Center" 
                                       Margin="0,0,0,10"/>
                            <TextBlock Text="Información del Sistema" 
                                       FontSize="16" 
                                       FontWeight="Bold" 
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="Ver detalles y estadísticas" 
                                       FontSize="12" 
                                       Foreground="#666666" 
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap"
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- Acerca de -->
                    <Button Grid.Row="1" Grid.Column="2" 
                            Style="{StaticResource ConfigButtonStyle}"
                            Click="BtnAcercaDe_Click"
                            Padding="10">
                        <StackPanel>
                            <TextBlock Text="❓" 
                                       FontSize="40" 
                                       HorizontalAlignment="Center" 
                                       Margin="0,0,0,10"/>
                            <TextBlock Text="Acerca de" 
                                       FontSize="16" 
                                       FontWeight="Bold" 
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="Versión y créditos" 
                                       FontSize="12" 
                                       Foreground="#666666" 
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap"
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Información Adicional -->
                <Border Style="{StaticResource CardStyle}" 
                        Background="#FFF9E6" 
                        Margin="5,20,5,0"
                        Padding="10">
                    <StackPanel>
                        <TextBlock Text="⚠️ Advertencia" 
                                   FontWeight="Bold" 
                                   FontSize="14" 
                                   Foreground="#F57C00"
                                   Margin="0,0,0,10"/>
                        <TextBlock TextWrapping="Wrap" 
                                   FontSize="12" 
                                   Foreground="#666666">
                            <Run Text="• Las opciones de configuración críticas solo están disponibles para"/>
                            <Run Text="Administradores" FontWeight="Bold"/>
                            <LineBreak/>
                            <Run Text="• Realiza respaldos periódicos de la base de datos"/>
                            <LineBreak/>
                            <Run Text="• Los cambios de contraseña son permanentes"/>
                            <LineBreak/>
                            <Run Text="• El historial eliminado no se puede recuperar"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>