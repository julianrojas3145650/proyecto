<Page x:Class="Proyecto_senavicola.view.pages.InicioPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:controls="clr-namespace:Proyecto_senavicola.view.controls"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1200"
      Background="#F5F5F5"
      Loaded="Page_Loaded">

    <Page.Resources>
        <!-- Estilos de Tarjetas Métricas -->
        <Style x:Key="MetricCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,15,0"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.15" BlurRadius="15" ShadowDepth="3"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.1" BlurRadius="10" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="QuickActionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="80"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" Opacity="0.1" BlurRadius="8" ShadowDepth="2"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#000000" Opacity="0.25" BlurRadius="12" ShadowDepth="4"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- NavBar -->
        <controls:NavBarControl x:Name="navBar" Grid.Row="0"/>

        <!-- Contenido Principal -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" 
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="30,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ==================== TARJETAS DE MÉTRICAS PRINCIPALES ==================== -->
                <Grid Grid.Row="0" Margin="0,0,0,25">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Tarjeta 1: Total Huevos -->
                    <Border Grid.Column="0" Style="{StaticResource MetricCardStyle}" Background="#1976D2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="HUEVOS DISPONIBLES" 
                                       Foreground="White" FontSize="12" FontWeight="SemiBold" 
                                       Opacity="0.9" Margin="0,0,0,5"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" x:Name="txtTotalHuevos" 
                                       Text="0" Foreground="White" FontSize="36" 
                                       FontWeight="Bold" Margin="0,0,0,5"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" x:Name="txtHuevosInfo" 
                                       Text="En inventario" Foreground="White" 
                                       FontSize="11" Opacity="0.8"/>

                            <Viewbox Grid.Row="0" Grid.RowSpan="3" Grid.Column="1" 
                                     Width="70" Height="70" Opacity="0.3">
                                <TextBlock Text="🥚" FontSize="60"/>
                            </Viewbox>
                        </Grid>
                    </Border>

                    <!-- Tarjeta 2: Total Gallinas -->
                    <Border Grid.Column="1" Style="{StaticResource MetricCardStyle}" Background="#179002">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="GALLINAS ACTIVAS" 
                                       Foreground="White" FontSize="12" FontWeight="SemiBold" 
                                       Opacity="0.9" Margin="0,0,0,5"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" x:Name="txtTotalGallinas" 
                                       Text="0" Foreground="White" FontSize="36" 
                                       FontWeight="Bold" Margin="0,0,0,5"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" x:Name="txtGallinasInfo" 
                                       Text="En producción" Foreground="White" 
                                       FontSize="11" Opacity="0.8"/>

                            <Viewbox Grid.Row="0" Grid.RowSpan="3" Grid.Column="1" 
                                     Width="70" Height="70" Opacity="0.3">
                                <TextBlock Text="🐔" FontSize="60"/>
                            </Viewbox>
                        </Grid>
                    </Border>

                    <!-- Tarjeta 3: Ventas del Mes -->
                    <Border Grid.Column="2" Style="{StaticResource MetricCardStyle}" Background="#FF9800">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="VENTAS DEL MES" 
                                       Foreground="White" FontSize="12" FontWeight="SemiBold" 
                                       Opacity="0.9" Margin="0,0,0,5"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" x:Name="txtVentasMes" 
                                       Text="$0" Foreground="White" FontSize="36" 
                                       FontWeight="Bold" Margin="0,0,0,5"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" x:Name="txtVentasInfo" 
                                       Text="0 huevos vendidos" Foreground="White" 
                                       FontSize="11" Opacity="0.8"/>

                            <Viewbox Grid.Row="0" Grid.RowSpan="3" Grid.Column="1" 
                                     Width="70" Height="70" Opacity="0.3">
                                <TextBlock Text="💰" FontSize="60"/>
                            </Viewbox>
                        </Grid>
                    </Border>

                    <!-- Tarjeta 4: Alertas -->
                    <Border Grid.Column="3" Style="{StaticResource MetricCardStyle}" Background="#F44336">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="ALERTAS" 
                                       Foreground="White" FontSize="12" FontWeight="SemiBold" 
                                       Opacity="0.9" Margin="0,0,0,5"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" x:Name="txtAlertas" 
                                       Text="0" Foreground="White" FontSize="36" 
                                       FontWeight="Bold" Margin="0,0,0,5"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" x:Name="txtAlertasInfo" 
                                       Text="Tareas pendientes" Foreground="White" 
                                       FontSize="11" Opacity="0.8"/>

                            <Viewbox Grid.Row="0" Grid.RowSpan="3" Grid.Column="1" 
                                     Width="70" Height="70" Opacity="0.3">
                                <TextBlock Text="🔔" FontSize="60"/>
                            </Viewbox>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ==================== SECCIÓN DE GRÁFICOS Y ESTADÍSTICAS ==================== -->
                <Grid Grid.Row="1" Margin="0,0,0,25">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Producción de Huevos por Tipo -->
                    <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,15,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="📊" FontSize="20" 
                                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Producción de Huevos por Tipo" 
                                               FontSize="16" FontWeight="Bold" 
                                               Foreground="#179002"/>
                                    <TextBlock Text="Distribución de huevos en inventario según clasificación" 
                                               FontSize="11" Foreground="#666666" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>

                            <Separator Background="#E0E0E0" Margin="0,0,0,15"/>

                            <!-- Gráfico de barras manual (simulado) -->
                            <Grid Height="220">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Jumbo -->
                                <Grid Grid.Column="0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" VerticalAlignment="Bottom" 
                                            Background="#FFC000" CornerRadius="5,5,0,0" 
                                            Margin="5,0" x:Name="barJumbo" Height="50">
                                        <TextBlock Text="0" Foreground="White" FontWeight="Bold" 
                                                   x:Name="txtBarJumbo" HorizontalAlignment="Center" 
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Grid.Row="1" Text="Jumbo" FontSize="11" 
                                               HorizontalAlignment="Center" Margin="0,5,0,2"/>
                                    <TextBlock Grid.Row="2" Text=">78g" FontSize="9" 
                                               Foreground="#666" HorizontalAlignment="Center"/>
                                </Grid>

                                <!-- AAA -->
                                <Grid Grid.Column="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" VerticalAlignment="Bottom" 
                                            Background="#FFD45C" CornerRadius="5,5,0,0" 
                                            Margin="5,0" x:Name="barAAA" Height="50">
                                        <TextBlock Text="0" Foreground="White" FontWeight="Bold" 
                                                   x:Name="txtBarAAA" HorizontalAlignment="Center" 
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Grid.Row="1" Text="AAA" FontSize="11" 
                                               HorizontalAlignment="Center" Margin="0,5,0,2"/>
                                    <TextBlock Grid.Row="2" Text="67-77g" FontSize="9" 
                                               Foreground="#666" HorizontalAlignment="Center"/>
                                </Grid>

                                <!-- AA -->
                                <Grid Grid.Column="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" VerticalAlignment="Bottom" 
                                            Background="#FAE669" CornerRadius="5,5,0,0" 
                                            Margin="5,0" x:Name="barAA" Height="50">
                                        <TextBlock Text="0" Foreground="#333" FontWeight="Bold" 
                                                   x:Name="txtBarAA" HorizontalAlignment="Center" 
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Grid.Row="1" Text="AA" FontSize="11" 
                                               HorizontalAlignment="Center" Margin="0,5,0,2"/>
                                    <TextBlock Grid.Row="2" Text="60-66g" FontSize="9" 
                                               Foreground="#666" HorizontalAlignment="Center"/>
                                </Grid>

                                <!-- A -->
                                <Grid Grid.Column="3">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" VerticalAlignment="Bottom" 
                                            Background="#BDBDBD" CornerRadius="5,5,0,0" 
                                            Margin="5,0" x:Name="barA" Height="50">
                                        <TextBlock Text="0" Foreground="White" FontWeight="Bold" 
                                                   x:Name="txtBarA" HorizontalAlignment="Center" 
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Grid.Row="1" Text="A" FontSize="11" 
                                               HorizontalAlignment="Center" Margin="0,5,0,2"/>
                                    <TextBlock Grid.Row="2" Text="53-59g" FontSize="9" 
                                               Foreground="#666" HorizontalAlignment="Center"/>
                                </Grid>

                                <!-- B -->
                                <Grid Grid.Column="4">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" VerticalAlignment="Bottom" 
                                            Background="#E0E0E0" CornerRadius="5,5,0,0" 
                                            Margin="5,0" x:Name="barB" Height="50">
                                        <TextBlock Text="0" Foreground="#333" FontWeight="Bold" 
                                                   x:Name="txtBarB" HorizontalAlignment="Center" 
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Grid.Row="1" Text="B" FontSize="11" 
                                               HorizontalAlignment="Center" Margin="0,5,0,2"/>
                                    <TextBlock Grid.Row="2" Text="46-52g" FontSize="9" 
                                               Foreground="#666" HorizontalAlignment="Center"/>
                                </Grid>

                                <!-- C -->
                                <Grid Grid.Column="5">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" VerticalAlignment="Bottom" 
                                            Background="#707070" CornerRadius="5,5,0,0" 
                                            Margin="5,0" x:Name="barC" Height="50">
                                        <TextBlock Text="0" Foreground="White" FontWeight="Bold" 
                                                   x:Name="txtBarC" HorizontalAlignment="Center" 
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Grid.Row="1" Text="C" FontSize="11" 
                                               HorizontalAlignment="Center" Margin="0,5,0,2"/>
                                    <TextBlock Grid.Row="2" Text="46g" FontSize="9" 
                                               Foreground="#666" HorizontalAlignment="Center"/>
                                </Grid>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Estado de Galpones -->
                    <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="0,0,15,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="🏠" FontSize="20" 
                                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Estado de Galpones" 
                                               FontSize="16" FontWeight="Bold" 
                                               Foreground="#179002"/>
                                    <TextBlock Text="Distribución actual" 
                                               FontSize="11" Foreground="#666666" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>

                            <Separator Background="#E0E0E0" Margin="0,0,0,15"/>

                            <StackPanel x:Name="stackGalpones">
                                <!-- Se llenará dinámicamente -->
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Actividad Reciente -->
                    <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="📋" FontSize="20" 
                                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Actividad Reciente" 
                                               FontSize="16" FontWeight="Bold" 
                                               Foreground="#179002"/>
                                    <TextBlock Text="Últimas acciones" 
                                               FontSize="11" Foreground="#666666" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>

                            <Separator Background="#E0E0E0" Margin="0,0,0,15"/>

                            <ScrollViewer Height="220" VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="stackActividad">
                                    <!-- Se llenará dinámicamente -->
                                </StackPanel>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ==================== ACCIONES RÁPIDAS ==================== -->
                <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,0,0,25">
                    <StackPanel>
                        <TextBlock Text="⚡ Acciones Rápidas" FontSize="18" 
                                   FontWeight="Bold" Foreground="#179002" Margin="0,0,0,20"/>

                        <UniformGrid Rows="1" Columns="8">
                            <Button Style="{StaticResource QuickActionButtonStyle}" 
                                    Background="#D32F2F" Click="BtnRegistrarHuevos_Click">
                                <StackPanel>
                                    <TextBlock Text="🥚" FontSize="28" Foreground="White"/>
                                    <TextBlock Text="Registrar" FontSize="9" Foreground="White" 
                                               HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                    <TextBlock Text="Huevos" FontSize="9" Foreground="White" 
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource QuickActionButtonStyle}" 
                                    Background="#00897B" Click="BtnGestionGallinas_Click">
                                <StackPanel>
                                    <TextBlock Text="🐔" FontSize="28" Foreground="White"/>
                                    <TextBlock Text="Gestión" FontSize="9" Foreground="White" 
                                               HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                    <TextBlock Text="Gallinas" FontSize="9" Foreground="White" 
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource QuickActionButtonStyle}" 
                                    Background="#7B1FA2" Click="BtnReportes_Click">
                                <StackPanel>
                                    <TextBlock Text="📊" FontSize="28" Foreground="White"/>
                                    <TextBlock Text="Ver" FontSize="9" Foreground="White" 
                                               HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                    <TextBlock Text="Reportes" FontSize="9" Foreground="White" 
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource QuickActionButtonStyle}" 
                                    Background="#F57C00" Click="BtnInsumos_Click">
                                <StackPanel>
                                    <TextBlock Text="📦" FontSize="28" Foreground="White"/>
                                    <TextBlock Text="Gestión" FontSize="9" Foreground="White" 
                                               HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                    <TextBlock Text="Insumos" FontSize="9" Foreground="White" 
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource QuickActionButtonStyle}" 
                                    Background="#0288D1" Click="BtnAlimentacion_Click">
                                <StackPanel>
                                    <TextBlock Text="🍽️" FontSize="28" Foreground="White"/>
                                    <TextBlock Text="Control" FontSize="9" Foreground="White" 
                                               HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                    <TextBlock Text="Alimentación" FontSize="9" Foreground="White" 
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource QuickActionButtonStyle}" 
                                    Background="#FFB300" Click="BtnVentas_Click">
                                <StackPanel>
                                    <TextBlock Text="💰" FontSize="28" Foreground="White"/>
                                    <TextBlock Text="Registrar" FontSize="9" Foreground="White" 
                                               HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                    <TextBlock Text="Ventas" FontSize="9" Foreground="White" 
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource QuickActionButtonStyle}" 
                                    Background="#5C6BC0" Click="BtnConfiguracion_Click">
                                <StackPanel>
                                    <TextBlock Text="⚙️" FontSize="28" Foreground="White"/>
                                    <TextBlock Text="Ir a" FontSize="9" Foreground="White" 
                                               HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                    <TextBlock Text="Config." FontSize="9" Foreground="White" 
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource QuickActionButtonStyle}" 
                                    Background="#37474F" Click="BtnActualizar_Click">
                                <StackPanel>
                                    <TextBlock Text="🔄" FontSize="28" Foreground="White"/>
                                    <TextBlock Text="Actualizar" FontSize="9" Foreground="White" 
                                               HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                    <TextBlock Text="Datos" FontSize="9" Foreground="White" 
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!-- ==================== INFORMACIÓN ADICIONAL ==================== -->
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Próximos Eventos -->
                    <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,15,0">
                        <StackPanel>
                            <TextBlock Text="📅 Próximos Eventos y Tareas" FontSize="16" 
                                       FontWeight="Bold" Foreground="#179002" Margin="0,0,0,15"/>
                            <Separator Background="#E0E0E0" Margin="0,0,0,15"/>

                            <StackPanel x:Name="stackEventos">
                                <!-- Se llenará dinámicamente -->
                                <TextBlock Text="No hay eventos programados" 
                                           Foreground="#999" FontStyle="Italic" 
                                           HorizontalAlignment="Center" Margin="0,20"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Resumen del Sistema -->
                    <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="ℹ️ Resumen del Sistema" FontSize="16" 
                                       FontWeight="Bold" Foreground="#179002" Margin="0,0,0,15"/>
                            <Separator Background="#E0E0E0" Margin="0,0,0,15"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Total Galpones:" 
                                           FontWeight="SemiBold" Margin="0,5"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtResumenGalpones" 
                                           Text="0" HorizontalAlignment="Right" Margin="0,5"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Lotes Activos:" 
                                           FontWeight="SemiBold" Margin="0,5"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtResumenLotes" 
                                           Text="0" HorizontalAlignment="Right" Margin="0,5"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Inventario Total:" 
                                           FontWeight="SemiBold" Margin="0,5"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtResumenInventario" 
                                           Text="0 huevos" HorizontalAlignment="Right" Margin="0,5"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Ventas Hoy:" 
                                           FontWeight="SemiBold" Margin="0,5"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="txtResumenVentasHoy" 
                                           Text="$0" HorizontalAlignment="Right" Margin="0,5"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Huevos Dañados:" 
                                           FontWeight="SemiBold" Margin="0,5"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" x:Name="txtResumenDanados" 
                                           Text="0" HorizontalAlignment="Right" Margin="0,5" 
                                           Foreground="#F44336"/>

                                <Separator Grid.Row="5" Grid.ColumnSpan="2" 
