<Window x:Class="Proyecto_senavicola.view.window.SeleccionCamaraDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Senavícola - Dashboard"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None">

    <Window.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="#179002"/>
            <Setter Property="Margin" Value="0,13,0,0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#26C007"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#128001"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LogoutButtonStyle" TargetType="Button" BasedOn="{StaticResource MenuButtonStyle}">
            <Setter Property="Background" Value="#8C0000"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#CC0000"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#C62828"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WindowCircleButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                CornerRadius="9"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.ColumnSpan="2" 
              Height="36" 
              Panel.ZIndex="999" 
              VerticalAlignment="Top" 
              Background="Transparent"
              MouseDown="TopBar_MouseDown">
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Center" 
                        Margin="0,0,10,0">

                <Button x:Name="btnMinimizar"
                Background="#00B6EB"
                Margin="4,0"
                Style="{StaticResource WindowCircleButtonStyle}"
                Click="BtnMinimizar_Click">
                    <TextBlock Text="─" 
                       Foreground="White" 
                       FontWeight="Bold" 
                       FontSize="10" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center"/>
                </Button>

                <Button x:Name="btnMaximizar"
                Background="#FFD700"
                Margin="4,0"
                Style="{StaticResource WindowCircleButtonStyle}"
                Click="BtnMaximizar_Click">
                    <TextBlock Text="⬜"
                       Foreground="White"
                       FontWeight="Bold"
                       FontSize="10"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
                </Button>

                <Button x:Name="btnCerrar"
                Background="#D14545"
                Margin="4,0,10,0"
                Style="{StaticResource WindowCircleButtonStyle}"
                Click="BtnCerrar_Click">
                    <TextBlock Text="×" 
                       Foreground="White" 
                       FontWeight="Bold" 
                       FontSize="10" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center"/>
                </Button>
            </StackPanel>
        </Grid>


        <Border Grid.Column="0" Background="#1FA303" CornerRadius="0,10,10,0">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="Senavicola"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0,10,0,10"/>

                    <Separator Margin="0,6"
                       Background="White"/>
                </StackPanel>

                <UniformGrid Grid.Row="1" Rows="8" VerticalAlignment="Stretch">
                    <Button x:Name="BtnInicio" Style="{StaticResource MenuButtonStyle}" Click="BtnInicio_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="🏠" FontSize="16" Margin="0,0,8,0" Padding="0,0,0,0"/>
                            <TextBlock Text="Inicio" FontSize="16"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnGallinas" Style="{StaticResource MenuButtonStyle}" Click="BtnGallinas_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="🐔" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock Text="Gestión de Gallinas" FontSize="16"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnHuevos" Style="{StaticResource MenuButtonStyle}" Click="BtnHuevos_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="🥚" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock Text="Gestión de Huevos" FontSize="16"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnInsumos" Style="{StaticResource MenuButtonStyle}" Click="BtnInsumos_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="📦" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock Text="Gestión de Insumos" FontSize="16"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnReportes" Style="{StaticResource MenuButtonStyle}" Click="BtnReportes_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="📊" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock Text="Reportes" FontSize="16"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnConfiguracion" Style="{StaticResource MenuButtonStyle}" Click="BtnConfiguracion_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="🔧" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock Text="Configuración" FontSize="16"/>
                        </StackPanel>
                    </Button>
                </UniformGrid>



                <StackPanel Grid.Row="2" Margin="0,20,0,0">
                    <Separator Background="White" Margin="0,20,0,10"/>
                    <Button Click="BtnCerrarSesion_Click" 
                    Style="{StaticResource LogoutButtonStyle}"
                    VerticalAlignment="Bottom">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="🚪" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock Text="Cerrar sesión" FontSize="16" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>


        <Frame x:Name="MainFrame" Grid.Column="1" NavigationUIVisibility="Hidden" Navigated="MainFrame_Navigated"/>
    </Grid>
</Window>
