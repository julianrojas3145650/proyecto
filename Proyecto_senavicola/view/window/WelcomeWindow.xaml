<Window x:Class="Proyecto_senavicola.view.window.WelcomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Proyecto_senavicola.view.window"
        mc:Ignorable="d"
        Title="WelcomeWindow" Height="550" Width="800"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        MouseDown="Window_MouseDown">

    <Border CornerRadius="12">
        <Border.Background>
            <ImageBrush ImageSource="/Images/Foto_sena.jpeg" 
                        Stretch="UniformToFill"/>
        </Border.Background>

        <Border CornerRadius="10" 
                BorderThickness="1">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#007832" Offset="0.75"/>
                    <GradientStop Color="#39A900" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="25"/>
                        <ColumnDefinition Width="25"/>
                        <ColumnDefinition Width="5"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="btnMinimizar"
                            Background="#346CE3"
                            BorderThickness="0"
                            Content="-"
                            Foreground="White"
                            FontSize="10"
                            Cursor="Hand"
                            Grid.Column="1"
                            Click="BtnMinimizar_Click" 
                            Margin="0,4,0,4">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#00B6EB"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#7ADDFF"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>

                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Width="18" 
                                        Height="18"
                                        CornerRadius="9"
                                        Background="{TemplateBinding Background}">
                                    <ContentPresenter VerticalAlignment="Center"
                                                      HorizontalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="btnCerrar"
                            Background="#D14545"
                            BorderThickness="0"
                            Content="x"
                            Foreground="White"
                            FontSize="10"
                            Cursor="Hand"
                            Grid.Column="2"
                            Click="BtnCerrar_Click" 
                            Margin="0,4,0,4">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#00B6EB"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#7ADDFF"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>

                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Width="18" 
                                        Height="18"
                                        CornerRadius="9"
                                        Background="{TemplateBinding Background}">
                                    <ContentPresenter VerticalAlignment="Center"
                                  HorizontalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <Border Grid.Row="1" 
                        Background="White"
                        Width="250" Height="320"
                        Margin="0,35,0,35"
                        CornerRadius="20" 
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <Image Source="/Images/Logo_sena.png"
                               Width="80" 
                               Margin="0,25,0,0"/>
                        <TextBlock Text="Bienvenido a Senavicola"
                                   Foreground="Gray" 
                                   FontSize="17" 
                                   FontFamily="Montserrat"
                                   HorizontalAlignment="Center" 
                                   Margin="0,30,0,0" 
                                   FontWeight="Bold"/>
                        <TextBlock Text="Optimiza, organiza y"
                                   Foreground="Gray"
                                   FontSize="11" 
                                   FontFamily="Montserrat"
                                   HorizontalAlignment="Center"
                                   Margin="0,20,0,0"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="supervisa cada detalle de tu producción."
                                   Foreground="Gray"
                                   FontSize="11" 
                                   FontFamily="Montserrat"
                                   HorizontalAlignment="Center" 
                                   Margin="0,1,0,0" 
                                   FontWeight="SemiBold"/>

                        <Grid Margin="0,25,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Button Content="Iniciar sesión" 
                                    Grid.Row="0"
                                    Width="140"
                                    Height="32"
                                    Foreground="White" 
                                    Background="#1FA303"
                                    Margin="0,0,0,12"
                                    Click="BtnSignIn_Click"
                                    Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                                CornerRadius="12"
                                                x:Name="border"
                                                Padding="4">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                                              TextElement.FontWeight="SemiBold"
                                                              TextElement.FontSize="13"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" 
                                                     Value="True">
                                                <Setter TargetName="border"
                                                        Property="Background"
                                                        Value="#007D00"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Button Content="Iniciar como invitado" 
                                    Grid.Row="1"
                                    Width="140"
                                    Height="32"
                                    Foreground="White" 
                                    Background="#1FA303"
                                    Click="BtnGuest_Click"
                                    Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                                CornerRadius="12"
                                                x:Name="border"
                                                Padding="4">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                                              TextElement.FontWeight="SemiBold"
                                                              TextElement.FontSize="13"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" 
                                                     Value="True">
                                                <Setter TargetName="border"
                                                        Property="Background"
                                                        Value="#007D00"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Border>
</Window>